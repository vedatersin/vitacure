@model vitacure.Models.ViewModels.Admin.TagFormViewModel

@{
    ViewData["Title"] = "Yeni Etiket";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page auth-page-admin">
    <div class="container auth-container auth-container-wide">
        <div class="auth-card auth-card-admin">
            <div class="auth-eyebrow">Etiket Yönetimi</div>
            <h1 class="auth-title">Yeni etiket oluştur</h1>
            <p class="auth-subtitle">Bu kayıt ürün formunda seçilebilir hale gelir ve gelecekte filtreleme için kullanılabilir.</p>

            <partial name="_Form" model="Model" />
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
