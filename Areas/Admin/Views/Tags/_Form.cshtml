@model vitacure.Models.ViewModels.Admin.TagFormViewModel

<form method="post" action="@Context.Request.Path" class="auth-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
    <div class="admin-operator-card mb-4">
        <span>Form Notu</span>
        <strong>Etiketler urun segmentasyonunda kullanilir</strong>
        <small>Filtreleme ve urun iliskileri icin kisa, tutarli slug yapisi kullan.</small>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control auth-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control auth-input" />
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>
    </div>

    <div class="auth-admin-actions mt-4">
        <button type="submit" class="btn auth-submit-btn auth-secondary-btn">Kaydet</button>
        <a href="/admin/tags" class="btn auth-submit-btn auth-tertiary-btn">Listeye Dön</a>
    </div>
</form>
