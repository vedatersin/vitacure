@using Microsoft.AspNetCore.Identity
@using vitacure.Domain.Entities
@inject UserManager<AppUser> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var currentUserRoles = currentUser is not null ? await UserManager.GetRolesAsync(currentUser) : Array.Empty<string>();
    var currentUserRoleLabel = currentUserRoles.FirstOrDefault() ?? "Admin";
    var currentUserDisplayName = currentUser?.FullName ?? "Vitacure Admin";
    var currentUserInitials = string.Concat(
        currentUserDisplayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0])));
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;
    var activeModule = currentController switch
    {
        "Orders" => "sales",
        "Users" => "customers",
        "Products" or "Categories" or "Tags" or "Brands" or "Features" or "Collections" or "Media" or "Showcases" or "HomeContent" => "catalog",
        "System" => "system",
        "Agents" or "Automations" => "agents",
        "Ai" => "ai",
        "Notifications" => "dashboard",
        _ => "dashboard"
    };
    var moduleLabel = activeModule switch
    {
        "sales" => "Satış ve Siparişler",
        "customers" => "Müşteri Yüzeyi",
        "catalog" => "Katalog",
        "agents" => "Otomasyon & Ajanlar",
        "system" => "Sistem",
        "ai" => "Vitacure AI",
        _ => "Gösterge Paneli"
    };

    var globalModules = new List<(string Key, string Label, string Icon, string Url)>
    {
        ("dashboard", "Panel", "fa-solid fa-house", "/admin/dashboard"),
        ("sales", "Satış", "fa-solid fa-bag-shopping", "/admin/orders"),
        ("customers", "Müşteri", "fa-solid fa-users", "/admin/users"),
        ("catalog", "Katalog", "fa-solid fa-capsules", "/admin/products"),
        ("system", "Sistem", "fa-solid fa-gears", "/admin/system/storage"),
        ("agents", "Otomasyon & Ajanlar", "fa-solid fa-robot", "/admin/agents"),
        ("ai", "Vitacure AI", "fa-solid fa-wand-magic-sparkles", "/admin/ai"),
    };

    var contextSections = activeModule switch
    {
        "dashboard" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Panel", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/dashboard", "Genel Bakış", "fa-solid fa-house", IsActive("Dashboard"), false, null),
                ("/admin/notifications", "Bildirim Merkezi", "fa-solid fa-bell", IsActive("Notifications"), false, null),
                ("/admin/orders", "Sipariş özetleri", "fa-solid fa-bag-shopping", false, false, null),
                ("/admin/products", "Katalog özeti", "fa-solid fa-capsules", false, false, null)
            })
        },
        "sales" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Satış", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/orders", "Siparişler", "fa-solid fa-bag-shopping", IsActive("Orders"), false, null),
                ("#", "Ödeme Akışları", "fa-solid fa-credit-card", false, true, "yakında"),
                ("#", "İadeler", "fa-solid fa-rotate-left", false, true, "yakında")
            })
        },
        "customers" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Müşteriler", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/users", "Kullanıcılar", "fa-solid fa-users", IsActive("Users"), false, null),
                ("#", "Adresler", "fa-solid fa-location-dot", false, true, "yakında"),
                ("#", "Destek Talepleri", "fa-solid fa-life-ring", false, true, "yakında")
            })
        },
        "catalog" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Katalog", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/products", "Ürünler", "fa-solid fa-capsules", IsActive("Products"), false, null),
                ("/admin/categories", "Kategoriler", "fa-solid fa-layer-group", IsActive("Categories"), false, null),
                ("/admin/tags", "Etiketler", "fa-solid fa-tags", IsActive("Tags"), false, null),
                ("/admin/brands", "Markalar", "fa-solid fa-award", IsActive("Brands"), false, "yeni"),
                ("/admin/features", "Özellikler", "fa-solid fa-sliders", IsActive("Features"), false, "yeni")
            }),
            ("Genişleme Katmanları", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/showcases", "Vitrinler", "fa-solid fa-panorama", IsActive("Showcases"), false, null),
                ("/admin/home-content", "Anasayfa", "fa-solid fa-house-circle-check", IsActive("HomeContent"), false, null),
                ("/admin/collections", "Koleksiyonlar", "fa-solid fa-box-archive", IsActive("Collections"), false, "hazır"),
                ("/admin/media", "Medya Kütüphanesi", "fa-solid fa-images", IsActive("Media"), false, "yeni")
            })
        },
        "system" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Sistem Ayarları", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/system/storage", "Dosya ve CDN", "fa-solid fa-cloud-arrow-up", IsActive("System", "Storage"), false, null)
            })
        },
        "agents" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Otomasyon & Ajanlar", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/agents", "Ajanlar", "fa-solid fa-robot", IsActive("Agents"), false, null),
                ("/admin/automations", "Otomasyonlar", "fa-solid fa-bolt", IsActive("Automations"), false, null),
                ("#", "Çalışma Geçmişi", "fa-solid fa-timeline", false, true, "yakında"),
                ("#", "Heartbeat Akışları", "fa-solid fa-wave-square", false, true, "yakında")
            })
        },
        "ai" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Vitacure AI", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/ai", "AI Paneli", "fa-solid fa-wand-magic-sparkles", IsActive("Ai"), false, null),
                ("#", "Prompt Kütüphanesi", "fa-solid fa-comment-dots", false, true, "yakında"),
                ("#", "Model Ayarları", "fa-solid fa-sliders", false, true, "yakında"),
                ("#", "Asistan Senaryoları", "fa-solid fa-brain", false, true, "yakında")
            })
        },
        "inbox" => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>
        {
            ("Inbox", new List<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)>
            {
                ("/admin/notifications", "Bildirim Merkezi", "fa-solid fa-bell", IsActive("Notifications"), false, null),
                ("#", "Audit Feed", "fa-solid fa-shield-halved", false, true, "yakında"),
                ("#", "Quality Queue", "fa-solid fa-circle-exclamation", false, true, "yakında")
            })
        },
        _ => new List<(string Title, IReadOnlyList<(string Url, string Label, string Icon, bool Active, bool Muted, string? Badge)> Links)>()
    };

    bool IsActive(string controller, string action = "Index")
        => string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
           && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Yönetim") | VitaCure Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="admin-body admin-module-@activeModule">
    <div class="admin-shell" data-admin-shell>
        <button type="button" class="admin-shell-backdrop" data-admin-shell-close aria-label="Navigasyonu kapat"></button>

        <div class="admin-sidebars">
            <aside class="admin-global-rail" data-admin-primary-rail>
                <div class="admin-global-rail-top">
                    <a href="/admin/dashboard" class="admin-rail-brand" aria-label="VitaCure Admin">
                        <img src="~/img/logo-mini.png" alt="VitaCure" class="admin-rail-brand-mark" />
                        <img src="~/img/logo.png" alt="VitaCure Admin" class="admin-rail-brand-copy" />
                    </a>

                    <nav class="admin-rail-nav" aria-label="Ana modüller">
                        @foreach (var module in globalModules)
                        {
                            <a href="@module.Url"
                               class="admin-rail-link @(string.Equals(activeModule, module.Key, StringComparison.OrdinalIgnoreCase) ? "is-active" : null)"
                               title="@module.Label"
                               aria-label="@module.Label">
                                <i class="@module.Icon"></i>
                                <span class="admin-rail-link-label">@module.Label</span>
                                <span class="admin-rail-tooltip">@module.Label</span>
                            </a>
                        }
                    </nav>
                </div>

                <div class="admin-global-rail-bottom">
                    <div class="admin-rail-profile" data-admin-rail-profile-menu>
                        <div class="admin-rail-profile-trigger">
                            <span class="admin-rail-profile-main">
                                <div class="admin-rail-notification" data-admin-rail-notification>
                                    <button type="button" class="admin-rail-profile-avatar admin-rail-profile-avatar-button" data-admin-rail-notification-toggle aria-label="Bildirimleri aç">
                                        <span class="admin-rail-profile-initials">@currentUserInitials</span>
                                        <span class="admin-rail-profile-badge is-empty" data-admin-notification-badge>0</span>
                                    </button>
                                    <section class="admin-rail-notification-panel" data-admin-notification-panel data-admin-notification-endpoint="/admin/notifications/summary" aria-label="Bildirim özeti">
                                        <div class="admin-rail-notification-panel-head">
                                            <strong>Bildirimler</strong>
                                            <span class="admin-rail-profile-badge is-empty" data-admin-notification-badge-clone>0</span>
                                        </div>
                                        <div class="admin-rail-notification-list" data-admin-notification-list>
                                            <div class="admin-rail-notification-empty">
                                                <strong>Yükleniyor</strong>
                                                <span>Son bildirimler hazırlanıyor.</span>
                                            </div>
                                        </div>
                                        <div class="admin-rail-notification-footer">
                                            <a href="/admin/notifications" class="admin-profile-link admin-rail-notification-more">
                                                <span>Tümünü Gör</span>
                                            </a>
                                        </div>
                                    </section>
                                </div>
                                <span class="admin-rail-profile-copy">
                                    <strong>@currentUserDisplayName</strong>
                                    <small>@currentUserRoleLabel</small>
                                </span>
                            </span>
                            <button type="button" class="admin-rail-profile-menu-toggle" data-admin-rail-profile-toggle aria-label="Profil menüsü">
                                <i class="fa-solid fa-ellipsis-vertical"></i>
                            </button>
                        </div>
                        <div class="admin-dropdown-panel admin-profile-panel admin-rail-profile-panel admin-rail-profile-actions">
                            <a href="/account" class="admin-profile-link">
                                <i class="fa-regular fa-user"></i>
                                <span>Hesabı Yönet</span>
                            </a>
                            <form method="post" action="/admin/logout">
                                <button type="submit" class="admin-profile-link admin-profile-link-button">
                                    <i class="fa-solid fa-right-from-bracket"></i>
                                    <span>Çıkış</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </aside>

            <aside class="admin-context-sidebar" data-admin-secondary-rail>
                <div class="admin-context-sidebar-head">
                    <strong>@moduleLabel</strong>
                </div>

                <div class="admin-context-sidebar-group">
                    @foreach (var navSection in contextSections)
                    {
                        <div class="admin-context-nav-section">
                            <nav class="admin-context-nav" aria-label="@navSection.Title">
                                @foreach (var link in navSection.Links)
                                {
                                    if (link.Muted)
                                    {
                                        <div class="admin-context-link is-muted">
                                            <i class="@link.Icon"></i>
                                            <span>@link.Label</span>
                                            <small class="admin-context-link-tooltip">@link.Label</small>
                                        </div>
                                    }
                                    else
                                    {
                                        <a href="@link.Url" class="admin-context-link @(link.Active ? "is-active" : null)">
                                            <i class="@link.Icon"></i>
                                            <span>@link.Label</span>
                                            <small class="admin-context-link-tooltip">@link.Label</small>
                                        </a>
                                    }
                                }
                            </nav>
                        </div>
                    }
                </div>
            </aside>
        </div>

        <div class="admin-main">
            <button type="button" class="admin-shell-floating-toggle" data-admin-shell-open aria-label="Menüyü aç">
                <i class="fa-solid fa-bars"></i>
            </button>
            <main class="admin-content">
                @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminToast.cshtml")
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/pages/admin-shell.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin-feedback.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
