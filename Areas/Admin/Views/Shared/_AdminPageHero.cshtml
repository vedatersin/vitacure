@model vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel

<section class="admin-page-header-simple">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminBreadcrumb.cshtml", Model.Breadcrumbs)
    @if (!string.IsNullOrWhiteSpace(Model.Title))
    {
        <div class="admin-page-header-simple-row">
            <h1 class="admin-page-header-simple-title">@Model.Title</h1>
        </div>
    }
</section>
