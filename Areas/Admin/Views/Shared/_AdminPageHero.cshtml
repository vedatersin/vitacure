@model vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel

<section class="admin-hero-card">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminBreadcrumb.cshtml", Model.Breadcrumbs)
    <div class="admin-page-hero">
        <div class="admin-page-hero-main">
            <div class="admin-page-hero-icon">
                <i class="@Model.IconClass"></i>
            </div>
            <div>
                <div class="admin-page-eyebrow">@Model.Eyebrow</div>
                <h2 class="admin-page-title">@Model.Title</h2>
                <p class="admin-page-subtitle">@Model.Description</p>
            </div>
        </div>
        @if (Model.Stats.Count > 0 || !string.IsNullOrWhiteSpace(Model.AsideTitle) || !string.IsNullOrWhiteSpace(Model.AsideText))
        {
            <aside class="admin-page-hero-aside">
                @if (Model.Stats.Count > 0)
                {
                    <div class="admin-hero-stat-list">
                        @foreach (var stat in Model.Stats)
                        {
                            <div class="admin-hero-stat @stat.ToneClass">
                                <span>@stat.Label</span>
                                <strong>@stat.Value</strong>
                            </div>
                        }
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.AsideTitle) || !string.IsNullOrWhiteSpace(Model.AsideText))
                {
                    <div class="admin-hero-manifest">
                        @if (!string.IsNullOrWhiteSpace(Model.AsideTitle))
                        {
                            <strong>@Model.AsideTitle</strong>
                        }
                        @if (!string.IsNullOrWhiteSpace(Model.AsideText))
                        {
                            <p>@Model.AsideText</p>
                        }
                    </div>
                }
            </aside>
        }
    </div>
</section>
