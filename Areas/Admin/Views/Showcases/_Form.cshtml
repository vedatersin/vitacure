@model vitacure.Models.ViewModels.Admin.ShowcaseFormViewModel

@{
    var selectedFeaturedIds = Model.SelectedFeaturedProductIds.Take(7).ToArray();
    var selectedProducts = selectedFeaturedIds
        .Select(id => Model.ProductOptions.FirstOrDefault(product => product.Id == id))
        .ToArray();
    var rootCategories = Model.CategoryOptions
        .Where(category => category.ParentId is null)
        .OrderBy(category => category.Name)
        .ToArray();
    var selectedCategoryIds = Model.SelectedCategoryIds
        .Where(id => id > 0)
        .Distinct()
        .ToArray();
}

<form method="post" action="@Context.Request.Path" enctype="multipart/form-data" class="auth-form" data-showcase-form>
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div class="admin-showcase-editor">
        <div class="admin-showcase-editor-bar">
            <nav class="admin-showcase-tab-nav" aria-label="Vitrin editor bölümleri">
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="info">Vitrin Bilgileri</button>
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="content">İçerik</button>
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="visual">Görsel & Mod</button>
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="products">Ürün Vitrini</button>
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="categories">Kategoriler</button>
                <button type="button" class="admin-showcase-tab-button" data-showcase-tab="seo">SEO</button>
            </nav>
            <div class="admin-showcase-editor-actions">
                <a href="/admin/showcases" class="btn auth-submit-btn auth-tertiary-btn">Iptal</a>
                <button type="submit" class="btn auth-submit-btn auth-secondary-btn">Kaydet</button>
            </div>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger admin-showcase-validation"></div>

        <div class="admin-showcase-layout">
            <div class="admin-showcase-main">
                <section class="admin-showcase-card" data-showcase-tab-panel="info">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">1. Vitrin Bilgileri</span>
                            <h3>Temel alanlar</h3>
                            <p>Vitrinin görünen başlığı, URL alani ve yayına dair temel kontroller burada toplanir.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-info-grid">
                        <div class="admin-showcase-field">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control auth-input" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="admin-showcase-field">
                            <label asp-for="Slug" class="form-label"></label>
                            <input asp-for="Slug" class="form-control auth-input" />
                            <div class="admin-showcase-helper">URL'de kullanilacak kısa isim.</div>
                            <span asp-validation-for="Slug" class="text-danger"></span>
                        </div>

                        <div class="admin-showcase-field">
                            <label asp-for="SortOrder" class="form-label"></label>
                            <input asp-for="SortOrder" class="form-control auth-input" type="number" step="1" />
                            <div class="admin-showcase-helper">Küçük sayi önce gösterilir.</div>
                        </div>

                        <div class="admin-showcase-field">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control auth-input" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="admin-showcase-field admin-showcase-icon-field">
                            <label asp-for="IconClass" class="form-label"></label>
                            <div class="admin-showcase-icon-row">
                                <input asp-for="IconClass" class="form-control auth-input" />
                                <input asp-for="IconColor" class="form-control form-control-color auth-input" type="color" />
                                <div class="admin-showcase-icon-preview">
                                    <i class="@Model.IconClass" style="color:@Model.IconColor;" data-showcase-icon-preview></i>
                                </div>
                            </div>
                            <span asp-validation-for="IconClass" class="text-danger"></span>
                            <span asp-validation-for="IconColor" class="text-danger"></span>
                        </div>

                        <div class="admin-showcase-field admin-showcase-toggle-field">
                            <span class="form-label d-block">Yayın durumu</span>
                            <div class="admin-showcase-toggle-stack">
                                <label class="admin-showcase-toggle">
                                    <input asp-for="IsActive" class="form-check-input" />
                                    <span>
                                        <strong>Aktif</strong>
                                        <small>Vitrin canli vitrin akışları için kullanilsin.</small>
                                    </span>
                                </label>
                                <label class="admin-showcase-toggle">
                                    <input asp-for="ShowOnHome" class="form-check-input" />
                                    <span>
                                        <strong>Ana Sayfada Göster</strong>
                                        <small>Home akisi içindeki pill ve sohbet dönüşümünde yer alsin.</small>
                                    </span>
                                </label>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="admin-showcase-card" data-showcase-tab-panel="content">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">2. Açıklama &amp; Ornek Sohbet Cumleleri</span>
                            <h3>Metin akisi</h3>
                            <p>Storefront açıklamasi ve home chat içinde dönen ornek cümleler bu blokta yönetilir.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-content-grid">
                        <div class="admin-showcase-field">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description"
                                      class="form-control auth-textarea admin-showcase-description-textarea"
                                      rows="8"
                                      data-showcase-description-input
                                      data-showcase-description-limit="@vitacure.Models.ViewModels.Admin.ShowcaseFormViewModel.MaxDescriptionLength"></textarea>
                            <div class="admin-showcase-field-foot">
                                <span class="text-danger small">Maksimum @vitacure.Models.ViewModels.Admin.ShowcaseFormViewModel.MaxDescriptionLength karakter girebilirsiniz.</span>
                                <strong class="admin-showcase-counter" data-showcase-description-counter>0 / @vitacure.Models.ViewModels.Admin.ShowcaseFormViewModel.MaxDescriptionLength</strong>
                            </div>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="admin-showcase-field">
                            <div class="admin-showcase-inline-head">
                                <label asp-for="ExamplePromptsContent" class="form-label mb-0"></label>
                                <button type="button" class="admin-showcase-add-prompt" data-showcase-add-prompt>
                                    <i class="fa-solid fa-plus"></i>
                                    <span>Ornek cumle ekle</span>
                                </button>
                            </div>
                            <div class="admin-showcase-helper mb-2">Kullanıcılarin sorabilecegi ornek sorulari surukleyerek sıralayabilirsin.</div>
                            <textarea asp-for="ExamplePromptsContent"
                                      class="form-control auth-textarea d-none"
                                      rows="5"
                                      data-showcase-prompts-textarea
                                      placeholder="Her satira bir sohbet cumlesi yazin"></textarea>
                            <div class="admin-showcase-prompts" data-showcase-prompts-list></div>
                            <div class="admin-showcase-prompts-empty" data-showcase-prompts-empty>Henüz ornek sohbet cumlesi eklenmedi.</div>
                            <span asp-validation-for="ExamplePromptsContent" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="admin-showcase-card" data-showcase-tab-panel="visual">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">3. Görsel &amp; Vitrin Modu</span>
                            <h3>Sahne ayari</h3>
                            <p>Arkaplan görseli ve light-dark tercihleri birlikte ele alinir.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-visual-grid">
                        <div class="admin-showcase-field">
                            <label asp-for="BackgroundImageUrl" class="form-label"></label>
                            <input asp-for="BackgroundImageUrl" type="hidden" />
                            <input asp-for="BackgroundImageFile"
                                   type="file"
                                   accept="image/png,image/jpeg,image/webp,image/gif"
                                   class="d-none"
                                   data-showcase-background-file-input />
                            <span asp-validation-for="BackgroundImageUrl" class="text-danger"></span>
                            <div class="admin-showcase-background-shell mt-2">
                                <button type="button"
                                        class="admin-showcase-background-preview @(string.IsNullOrWhiteSpace(Model.BackgroundImageUrl) ? "is-empty" : null)"
                                        data-showcase-background-preview
                                        aria-label="Arkaplan görselini onizle">
                                    <img src="@Model.BackgroundImageUrl"
                                         alt="@Model.Title"
                                         data-showcase-background-preview-image
                                         @(string.IsNullOrWhiteSpace(Model.BackgroundImageUrl) ? "hidden" : null) />
                                    <span class="admin-showcase-background-empty" data-showcase-background-empty @(string.IsNullOrWhiteSpace(Model.BackgroundImageUrl) ? null : "hidden")>
                                        <i class="fa-solid fa-cloud-arrow-up"></i>
                                        <strong>Görsel seçebilirsiniz</strong>
                                        <small>Browse ile bir arkaplan görseli seçin</small>
                                    </span>
                                    <span class="admin-showcase-background-actions">
                                        <span class="admin-showcase-background-action" data-showcase-background-remove title="Görseli kaldir" @(string.IsNullOrWhiteSpace(Model.BackgroundImageUrl) ? "hidden" : null)>
                                            <i class="fa-solid fa-xmark"></i>
                                        </span>
                                    </span>
                                </button>
                            </div>
                            <button type="button" class="btn auth-submit-btn auth-tertiary-btn admin-showcase-upload-trigger" data-showcase-background-trigger>
                                Görsel değiştir
                            </button>
                        </div>

                        <div class="admin-showcase-field">
                            <label asp-for="IsDark" class="form-label"></label>
                            <div class="auth-checkbox-grid admin-showcase-theme-grid">
                                <label class="auth-checkbox-card admin-showcase-theme-card" for="showcase-theme-dark" data-showcase-theme-card>
                                    <input type="radio"
                                           asp-for="IsDark"
                                           id="showcase-theme-dark"
                                           data-showcase-theme-option
                                           value="true" />
                                    <span>Dark</span>
                                    <small>Daha kontrastli vitrin metni ve koyu yuzeyler.</small>
                                </label>
                                <label class="auth-checkbox-card admin-showcase-theme-card" for="showcase-theme-light" data-showcase-theme-card>
                                    <input type="radio"
                                           asp-for="IsDark"
                                           id="showcase-theme-light"
                                           data-showcase-theme-option
                                           value="false" />
                                    <span>Light</span>
                                    <small>Daha ferah, açık yuzeyli storefront sunumu.</small>
                                </label>
                            </div>
                            <span asp-validation-for="IsDark" class="text-danger"></span>
                        </div>
                    </div>
                </section>

                <section class="admin-showcase-card" data-showcase-tab-panel="products">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">4. Ürün Vitrini</span>
                            <h3>Öne çıkan ürün slotlari</h3>
                            <p>Bu alan tasarim dokumaninda yer almiyor ama mevcut sistemde vitrin sahnesini besledigi için ayni kart diline tasindi.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-product-slots" data-showcase-product-slots>
                        @for (var index = 0; index < 7; index++)
                        {
                            var selectedProduct = index < selectedProducts.Length ? selectedProducts[index] : null;
                            <button type="button"
                                    class="admin-showcase-product-slot @(selectedProduct is not null ? "has-product" : null)"
                                    draggable="@(selectedProduct is not null ? "true" : "false")"
                                    data-showcase-slot
                                    data-slot-index="@index"
                                    data-product-id="@(selectedProduct?.Id ?? 0)">
                                <span class="admin-showcase-product-slot-index">@(index + 1)</span>
                                <div class="admin-showcase-product-slot-body">
                                    @if (selectedProduct is not null)
                                    {
                                        <img src="@selectedProduct.ImageUrl" alt="@selectedProduct.Name" />
                                        <strong>@selectedProduct.Name</strong>
                                        <small>@selectedProduct.CategoryName</small>
                                    }
                                    else
                                    {
                                        <strong>Ürün Seç</strong>
                                        <small>Bu slot için vitrin ürünü ekle</small>
                                    }
                                </div>
                            </button>
                        }
                    </div>

                    <div data-showcase-selected-inputs>
                        @foreach (var productId in selectedFeaturedIds)
                        {
                            <input type="hidden" name="SelectedFeaturedProductIds" value="@productId" />
                        }
                    </div>
                </section>
            </div>

            <aside class="admin-showcase-sidebar">
                <section class="admin-showcase-card admin-showcase-sidebar-card" data-showcase-tab-panel="categories">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">Kategori Seçimi</span>
                            <h3>Kategori baglanti noktasi</h3>
                            <p>Ana kategori önce seçilir, alt kategori havuzu seçime göre dinamik olarak dolar.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-field">
                        <label asp-for="PrimaryCategoryId" class="form-label"></label>
                        <select asp-for="PrimaryCategoryId" class="form-control auth-input">
                            <option value="">Ana kategori seçin</option>
                            @foreach (var category in rootCategories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <div class="admin-showcase-helper">Home chat akisi ve vitrinin ana kategori baglanti noktasi olarak kullanilir.</div>
                        <span asp-validation-for="PrimaryCategoryId" class="text-danger"></span>
                    </div>

                    <div class="admin-showcase-category-pool" data-showcase-category-pool>
                        <div class="admin-showcase-category-pool-head">
                            <strong>Alt kategoriler</strong>
                            <span>Ana kategori seçildiginde alt kategoriler burada dolar. Birden fazla alt kategori varsa çıkartabilir ve surukleyip sıralayabilirsin.</span>
                        </div>
                        <div class="admin-showcase-category-pool-list" data-showcase-category-pool-list></div>
                        <div class="admin-showcase-category-pool-empty" data-showcase-category-pool-empty>Ana kategori seçildiginde alt kategoriler burada görünecek.</div>
                        <div class="admin-showcase-category-summary" data-showcase-category-summary>0 alt kategori seçildi</div>
                        <div data-showcase-selected-categories>
                            @foreach (var categoryId in selectedCategoryIds)
                            {
                                <input type="hidden" name="SelectedCategoryIds" value="@categoryId" />
                            }
                        </div>
                        <div data-showcase-category-options hidden>
                            @foreach (var category in Model.CategoryOptions)
                            {
                                <div data-showcase-category-option
                                     data-category-id="@category.Id"
                                     data-category-name="@category.Name"
                                     data-category-parent-id="@(category.ParentId?.ToString() ?? string.Empty)"
                                     data-category-slug="@category.Slug"></div>
                            }
                        </div>
                    </div>
                </section>

                <section class="admin-showcase-card admin-showcase-sidebar-card" data-showcase-tab-panel="seo">
                    <div class="admin-showcase-card-head">
                        <div>
                            <span class="admin-showcase-card-step">SEO &amp; Meta</span>
                            <h3>Arama görünürlugu</h3>
                            <p>Sayfa başlığı ve meta açıklamasi kategori kartindan bagimsiz bir blokta durur.</p>
                        </div>
                    </div>

                    <div class="admin-showcase-field">
                        <label asp-for="SeoTitle" class="form-label"></label>
                        <input asp-for="SeoTitle" class="form-control auth-input" />
                    </div>

                    <div class="admin-showcase-field">
                        <label asp-for="MetaDescription" class="form-label"></label>
                        <textarea asp-for="MetaDescription" class="form-control auth-textarea" rows="4"></textarea>
                    </div>
                </section>
            </aside>
        </div>
    </div>
</form>

<div class="admin-showcase-image-modal" data-showcase-image-modal hidden>
    <button type="button" class="admin-showcase-image-modal-backdrop" data-showcase-image-modal-close aria-label="Kapat"></button>
    <div class="admin-showcase-image-modal-dialog">
        <button type="button" class="admin-icon-button admin-showcase-image-modal-dismiss" data-showcase-image-modal-close aria-label="Kapat">
            <i class="fa-solid fa-xmark"></i>
        </button>
        <img src="" alt="Arkaplan onizleme" data-showcase-image-modal-image />
    </div>
</div>

<div class="admin-showcase-picker-backdrop" data-showcase-picker hidden>
    <div class="admin-showcase-picker">
        <div class="admin-showcase-picker-head">
            <div>
                <strong>Ürün Havuzu</strong>
                <span>Seçilen kategorilerdeki ürünlerden vitrin slotunu doldur.</span>
            </div>
            <button type="button" class="admin-icon-button" data-showcase-picker-close aria-label="Kapat">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <div class="admin-showcase-picker-toolbar">
            <input type="search" class="form-control auth-input" placeholder="Ürün adi ara..." data-showcase-product-search />
            <select class="form-control auth-input" data-showcase-product-category-filter>
                <option value="">Tüm kategoriler</option>
            </select>
        </div>

        <div class="admin-showcase-picker-list" data-showcase-picker-list>
            @foreach (var product in Model.ProductOptions)
            {
                var tagNames = product.TagNames.Any()
                    ? string.Join("|", product.TagNames)
                    : string.Empty;
                <button type="button"
                        class="admin-showcase-picker-item"
                        data-showcase-picker-item
                        data-product-id="@product.Id"
                        data-category-id="@product.CategoryId"
                        data-category-slug="@product.CategorySlug"
                        data-product-name="@product.Name"
                        data-product-category="@product.CategoryName"
                        data-product-tags="@tagNames">
                    <img src="@product.ImageUrl" alt="@product.Name" />
                    <div>
                        <strong>@product.Name</strong>
                        <small>@product.CategoryName</small>
                        @if (product.TagNames.Any())
                        {
                            <span>@string.Join(", ", product.TagNames)</span>
                        }
                    </div>
                </button>
            }
        </div>
        <div class="admin-showcase-picker-empty" data-showcase-picker-empty hidden>
            Bu vitrinle eslesen bir ürün bulunmadi.
        </div>
    </div>
</div>
