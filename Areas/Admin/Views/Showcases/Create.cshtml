@model vitacure.Models.ViewModels.Admin.ShowcaseFormViewModel

@{
    ViewData["Title"] = "Vitrin Olustur";

    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Storefront Kurgusu",
        Title = "Yeni vitrin olustur",
        Description = "Vitrin, kategori taksonomisinden ayri bir landing modulu olarak calisir.",
        IconClass = "fa-solid fa-panorama",
        AsideTitle = "Form akis notu",
        AsideText = "Arkaplan, one cikan urunler ve kategori havuzu storefront vitrin sayfasini dogrudan etkiler.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Mod", Value = "Yeni" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Home", Value = Model.ShowOnHome ? "Acik" : "Kapali" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Vitrinler", Url = "/admin/showcases" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Yeni", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)
    <section class="admin-section-card">
        @await Html.PartialAsync("~/Areas/Admin/Views/Showcases/_Form.cshtml", Model)
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin-showcase-form.js" asp-append-version="true"></script>
}
