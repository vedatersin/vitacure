@model vitacure.Models.ViewModels.Admin.UserListViewModel

@{
    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Erisim Yönetimi",
        Title = "Kullanici listesi",
        Description = "Müşteri ve backoffice hesaplari ayrık hesap tipleriyle tek ekranda izleniyor.",
        IconClass = "fa-solid fa-users",
        AsideTitle = "Hesap Özeti",
        AsideText = "Müşteri ve yönetim hesap dagilimi bu bolumde ust seviye bir kontrol noktasi olarak görünür.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Toplam", Value = Model.TotalCount.ToString() },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Müşteri", Value = Model.CustomerCount.ToString() },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Yönetim", Value = Model.BackOfficeCount.ToString() }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Kullanicilar", IsActive = true }
        }
    };

    var filterBar = new vitacure.Models.ViewModels.Admin.AdminFilterBarViewModel
    {
        ActionUrl = "/admin/users",
        SearchPlaceholder = "Kullanici ara, rol filtrele, durum seç...",
        SearchValue = Model.SearchTerm,
        Selects = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminFilterSelectViewModel
            {
                Name = "accountType",
                Label = "Hesap Tipi",
                Value = Model.AccountTypeFilter,
                Options = new[]
                {
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "all", Label = "Tüm hesaplar" },
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "customer", Label = "Müşteri" },
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "backoffice", Label = "Yönetim" }
                }
            },
            new vitacure.Models.ViewModels.Admin.AdminFilterSelectViewModel
            {
                Name = "status",
                Label = "Durum",
                Value = Model.StatusFilter,
                Options = new[]
                {
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "all", Label = "Tüm durumlar" },
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "active", Label = "Aktif" },
                    new vitacure.Models.ViewModels.Admin.AdminFilterOptionViewModel { Value = "passive", Label = "Pasif" }
                }
            }
        }
    };
}

@await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)

<section class="admin-section-card">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminFilterBar.cshtml", filterBar)

    <div class="admin-table-wrap">
        <table class="table auth-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Ad Soyad</th>
                    <th>E-posta</th>
                    <th>Hesap Tipi</th>
                    <th>Rol</th>
                    <th>Durum</th>
                    <th>Oluşturulma</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td>@user.AccountTypeLabel</td>
                        <td>@user.RoleSummary</td>
                        <td>
                            <span class="auth-status-badge @(user.IsActive ? "is-active" : "is-passive")">
                                @(user.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>
                        <td>@user.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
