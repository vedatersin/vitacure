@{
    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Yapay Calisma Katmani",
        Title = "AI",
        Description = "Model yonetimi, prompt akislari ve akilli yardimci panelleri icin acilan temel alan.",
        IconClass = "fa-solid fa-sparkles",
        AsideTitle = "Hazirlik Notu",
        AsideText = "Bu sayfa kasitli olarak bos temel halinde acildi. AI ayarlari ve uygulama ici akilli paneller sonraki adimda burada toplanabilir.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Durum", Value = "Hazir" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Panel", Value = "Yakinda" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "AI", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)
    <section class="admin-section-card">
        <h2>AI merkezi hazir</h2>
        <p>Model secimi, akilli ozetler, prompt kutuphaneleri ve yonetim yardimcilari icin temel modul olusturuldu.</p>
