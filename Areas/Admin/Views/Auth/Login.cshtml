@model vitacure.Models.ViewModels.Auth.LoginViewModel

@{
    Layout = "~/Areas/Admin/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Yonetim Girisi";
}

<div class="auth-page auth-page-admin">
    <div class="container auth-container">
        <div class="auth-card auth-card-admin">
            <div class="auth-eyebrow">Yonetim Girisi</div>
            <h1 class="auth-title">Admin paneline giris yap</h1>
            <p class="auth-subtitle">Bu alan storefront'tan bagimsiz backoffice olarak dusunuluyor. Bugun /yonetim ve /admin altinda; ileride admin subdomain'e tasinabilir.</p>

            <div class="admin-operator-card mb-4">
                <span>Gelistirme kisayolu</span>
                <strong>/yonetim</strong>
                <small>Path tabanli kisayol, subdomain gecisi icin gecici kopru.</small>
            </div>

            <form method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control auth-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control auth-input" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn auth-submit-btn">Admin Girisi</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
