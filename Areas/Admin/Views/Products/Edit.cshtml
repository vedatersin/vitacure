@model vitacure.Models.ViewModels.Admin.ProductFormViewModel

@{
    ViewData["Title"] = "Urun Duzenle";

    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Katalog Yonetimi",
        Title = "Urunu duzenle",
        Description = "Storefront tarafinda gorunen alanlari bozmadan urun kaydini guncelleyebilirsin.",
        IconClass = "fa-solid fa-pen-ruler",
        AsideTitle = "Form akis notu",
        AsideText = "Duzenleme ekraninda fiyat, stok ve kategori degisiklikleri aninda katalog davranisini etkiler. Urun durumu ve secili kategori kontrol edilmeli.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Kayit", Value = Model.Id?.ToString() ?? "-" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Durum", Value = Model.IsActive ? "Aktif" : "Pasif" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Urunler", Url = "/admin/products" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Duzenle", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminCompactHeader.cshtml", hero)
    <partial name="_Form" model="Model" />
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin-product-gallery.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin-product-form.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin-product-variants.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin-richtext.js" asp-append-version="true"></script>
}
