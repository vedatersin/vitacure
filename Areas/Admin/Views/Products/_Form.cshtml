        <div class="admin-product-dialog-layer" data-feature-selector-modal hidden>
            <button type="button" class="admin-product-dialog-backdrop" data-feature-modal-close></button>
            <div class="admin-product-dialog admin-product-feature-dialog">
                <div class="admin-product-dialog-head">
                    <div>
                        <h3>Filtre Ekle</h3>
                    </div>
                    <button type="button" class="admin-icon-button" data-feature-modal-close aria-label="Kapat">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="admin-product-feature-groups">
                    @foreach (var group in featureGroups)
                    {
                        <section class="admin-product-feature-group-card">
                            <header>
                                <strong>@group.Key</strong>
                                <span>@group.Count() alan</span>
                            </header>

                            <div class="admin-product-feature-list">
                                @foreach (var feature in group)
                                {
                                    var isChecked = Model.SelectedFeatureIds.Contains(feature.Id);
                                    var selectedValue = Model.SelectedFeatureValues.TryGetValue(feature.Id, out var featureValue) ? featureValue : string.Empty;
                                    <div class="admin-product-feature-choice @(isChecked ? "is-selected" : null)" data-feature-option-group data-feature-id="@feature.Id" data-feature-group-name="@group.Key" data-feature-name="@feature.Name">
                                        <label class="admin-product-feature-toggle">
                                            <input type="checkbox" name="SelectedFeatureIds" value="@feature.Id" data-feature-checkbox @(isChecked ? "checked" : null) />
                                            <span class="admin-product-feature-copy">
                                                <strong>@feature.Name</strong>
                                                @if (!string.IsNullOrWhiteSpace(feature.OptionsPreview))
                                                {
                                                    <small>@feature.OptionsPreview</small>
                                                }
                                            </span>
                                        </label>

                                        @if (feature.Options.Count > 0)
                                        {
                                            <div class="admin-product-feature-options" data-feature-select>
                                                @foreach (var option in feature.Options)
                                                {
                                                    var radioId = $"feature-{feature.Id}-{option.ToLowerInvariant().Replace(" ", "-")}";
                                                    <label class="admin-product-feature-pill">
                                                        <input type="radio" id="@radioId" name="SelectedFeatureValues[@feature.Id]" value="@option" data-feature-value-option @(string.Equals(selectedValue, option, StringComparison.OrdinalIgnoreCase) ? "checked" : null) />
                                                        <span>@option</span>
                                                    </label>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </section>
                    }
                </div>

                <div class="admin-product-confirm-actions">
                    <button type="button" class="admin-editor-secondary" data-feature-modal-cancel>Vazgec</button>
                    <button type="button" class="admin-editor-primary" data-feature-modal-save>Kaydet</button>
                </div>
            </div>
        </div>
    </div>
</form>

