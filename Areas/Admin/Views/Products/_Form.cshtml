                        </span>
                    </button>
                    <div class="admin-product-media-toolbar">
                        <button type="button" class="admin-editor-secondary" data-category-image-clear hidden>
                            <span>Görseli Kaldir</span>
                        </button>
                    </div>
                </div>
            </div>

            <div>
                <label class="form-label">Siralama Ölçütü</label>
                <select class="form-select auth-input" data-category-create-sort>
                    <option value="">Siralama olcutu seciniz</option>
                    @foreach (var option in new[] { "One Cikanlar", "En Yeniler", "Fiyat Artan", "Fiyat Azalan", "En Cok Satanlar", "Puana Gore" })
                    {
                        <option value="@option">@option</option>
                    }
                </select>
            </div>

            <div>
                <label class="form-label">Slug</label>
                <input type="text" class="form-control auth-input" data-category-create-slug />
                <small class="text-danger" data-category-create-error="Slug"></small>
            </div>

            <div>
                <label class="form-label">Sayfa Basligi</label>
                <input type="text" class="form-control auth-input" data-category-create-seo-title />
            </div>

            <div>
                <label class="form-label">Meta Açıklama</label>
                <textarea class="form-control auth-textarea" rows="3" data-category-create-meta-description></textarea>
            </div>

            <div class="admin-product-field-span">
                <label class="admin-product-check-row">
                    <input type="checkbox" class="form-check-input" checked data-category-create-active />
                    <span>Bu sayfayi arama motorlarinin taramasina acik birak</span>
                </label>
            </div>
        </div>

        <div class="admin-product-confirm-actions">
            <button type="button" class="admin-editor-secondary" data-category-create-close>Vazgec</button>
            <button type="button" class="admin-editor-primary" data-category-create-save>Kaydet</button>
        </div>
    </div>
</div>

