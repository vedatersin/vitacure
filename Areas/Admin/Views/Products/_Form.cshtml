@using System.Text.Json
@using vitacure.Domain.Enums
@model vitacure.Models.ViewModels.Admin.ProductFormViewModel
@{
    var allCategories = Model.CategoryOptions.ToList();
    var parentCategories = allCategories.Where(option => option.ParentId is null).OrderBy(option => option.Name).ToList();
    var selectedCategory = allCategories.FirstOrDefault(option => option.Id == Model.CategoryId);
    var selectedCategoryIds = Model.SelectedCategoryIds
        .Append(Model.CategoryId ?? 0)
        .Where(id => id > 0)
        .Distinct()
        .ToHashSet();
    var selectedParentId = selectedCategory?.ParentId ?? (parentCategories.Any(option => option.Id == Model.CategoryId) ? Model.CategoryId ?? 0 : 0);
    var selectedChildId = selectedCategory?.ParentId is not null ? Model.CategoryId ?? 0 : 0;
    var selectedCategoryLabel = selectedCategory is null
        ? "Kategori secilmedi"
        : selectedCategory.ParentId is null
            ? selectedCategory.Name
            : $"{parentCategories.FirstOrDefault(option => option.Id == selectedCategory.ParentId)?.Name ?? "Kategori"} / {selectedCategory.Name}";
    var selectedFeatures = Model.FeatureOptions.Where(feature => Model.SelectedFeatureIds.Contains(feature.Id)).ToList();
    var selectedCustomFields = Model.CustomFieldOptions.Where(option => Model.SelectedCustomFieldIds.Contains(option.Id)).OrderBy(option => option.Name).ToList();
    var selectedPersonalizations = Model.PersonalizationOptions.Where(option => Model.SelectedPersonalizationIds.Contains(option.Id)).OrderBy(option => option.Name).ToList();
    var selectedTags = Model.TagOptions.Where(tag => Model.SelectedTagIds.Contains(tag.Id)).ToList();
    var variants = Model.Variants.ToList();
    var bundleItems = Model.BundleItems.OrderBy(item => item.ParentVariantId ?? 0).ThenBy(item => item.SortOrder).ToList();
    var featureGroups = Model.FeatureOptions.GroupBy(feature => feature.GroupName).OrderBy(group => group.Key).ToList();
    var isBundleMode = string.Equals(Model.CreateMode, "bundle", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Model.CreateMode, "bundle-variant", StringComparison.OrdinalIgnoreCase)
        || Model.ProductKind == ProductKind.Bundle;
    var isBundleVariantMode = string.Equals(Model.CreateMode, "bundle-variant", StringComparison.OrdinalIgnoreCase)
        || (isBundleMode && string.Equals(Model.BundleMode, "variant", StringComparison.OrdinalIgnoreCase))
        || (isBundleMode && variants.Count > 0);
    var isVariantMode = string.Equals(Model.CreateMode, "variant", StringComparison.OrdinalIgnoreCase) || isBundleVariantMode || variants.Count > 0;
    var shouldRenderVariantSection = isVariantMode || isBundleMode;
    var initialTab = isBundleMode ? "bundle-type" : "basic";
    var pageTitle = Model.Id.HasValue
        ? isBundleMode
            ? (isBundleVariantMode ? "Varyantli Paket Ürünü Düzenle" : "Paket Ürünü Düzenle")
            : (isVariantMode ? "Varyantli Ürünü Düzenle" : "Basit Ürünü Düzenle")
        : isBundleMode
            ? (isBundleVariantMode ? "Varyantli Paket Ürün Ekle" : "Paket Ürün Ekle")
            : (isVariantMode ? "Varyantli Ürün Ekle" : "Basit Ürün Ekle");
    var hasReviewSummary = Model.ReviewCount > 0;
    var roundedRating = (int)Math.Round(Math.Clamp(Model.Rating, 0m, 5m), MidpointRounding.AwayFromZero);
    var categorySelectorPayload = JsonSerializer.Serialize(allCategories.Select(option => new
    {
        option.Id,
        option.Name,
        option.ParentId
    }));
    var tagSelectorPayload = JsonSerializer.Serialize(Model.TagOptions.Select(option => new
    {
        option.Id,
        option.Name,
        option.Slug
    }));
    var customFieldPayload = JsonSerializer.Serialize(Model.CustomFieldOptions.Select(option => new
    {
        option.Id,
        option.Name,
        option.Slug,
        option.FieldType,
        option.IsFilterable
    }));
    var personalizationPayload = JsonSerializer.Serialize(Model.PersonalizationOptions.Select(option => new
    {
        option.Id,
        option.Name,
        option.Slug,
        option.InputType
    }));
    var variantGroupsPayload = JsonSerializer.Serialize(Model.VariantGroups.Select(group => new
    {
        group.Id,
        group.Name,
        group.SelectionStyle,
        group.ShowOnCard,
        group.IsPrimary,
        group.SortOrder,
        Options = group.Options.Select(option => new
        {
            option.Id,
            option.Name,
            option.ColorHex,
            option.SwatchImageUrl,
            option.SortOrder
        })
    }));
    var variantRowsPayload = JsonSerializer.Serialize(variants.Select(variant => new
    {
        variant.Id,
        variant.DisplayName,
        variant.GroupName,
        variant.OptionName,
        variant.ImageUrl,
        variant.Sku,
        variant.Barcode,
        variant.Price,
        variant.OldPrice,
        variant.PurchasePrice,
        variant.Stock,
        variant.Desi,
        variant.HsCode,
        variant.SortOrder,
        variant.IsDefault,
        variant.IsActive,
        variant.OptionIds
    }));
    var variantPresetsPayload = JsonSerializer.Serialize(Model.VariantPresets.Select(preset => new
    {
        preset.Name,
        preset.SelectionStyle,
        Options = preset.Options.Select(option => new
        {
            option.Name,
            option.ColorHex,
            option.SwatchImageUrl
        })
    }));
    var variantFieldVisibilityPayload = JsonSerializer.Serialize(new
    {
        Model.VariantFieldVisibility.ShowImage,
        Model.VariantFieldVisibility.ShowBarcode,
        Model.VariantFieldVisibility.ShowPurchasePrice,
        Model.VariantFieldVisibility.ShowDesi,
        Model.VariantFieldVisibility.ShowHsCode
    });
    var bundleProductsPayload = JsonSerializer.Serialize(Model.BundleProductOptions.Select(product => new
    {
        product.Id,
        product.Name,
        product.Slug,
        product.ImageUrl,
        product.Price,
        product.Stock,
        product.HasVariants,
        Variants = product.Variants.Select(variant => new
        {
            variant.Id,
            variant.Label,
            variant.Price,
            variant.Stock
        })
    }));
    var bundleItemsPayload = JsonSerializer.Serialize(bundleItems.Select(item => new
    {
        item.Id,
        item.ParentVariantId,
        item.ProductId,
        item.ProductVariantId,
        item.EntryMode,
        item.ProductName,
        item.ProductImageUrl,
        item.ProductVariantLabel,
        item.UnitPrice,
        item.Quantity,
        item.MinQuantity,
        item.MaxQuantity,
        item.SortOrder
    }));
}

<form method="post" action="@Context.Request.Path" class="auth-form admin-product-form-shell" data-admin-product-form="true" data-product-initial-tab="@initialTab">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="CreateMode" type="hidden" />
    <input asp-for="BundleMode" type="hidden" data-bundle-mode-input />
    <input asp-for="BundlePricingMode" type="hidden" data-bundle-pricing-mode-input />
    <input type="hidden" value="@Model.BundleAdjustmentType" data-bundle-adjustment-type-input />
    <input asp-for="CategoryId" type="hidden" data-product-category-input />
    <input asp-for="Status" type="hidden" data-product-status-input />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="admin-product-single-shell" data-product-page-shell>
        <header class="admin-product-page-intro" data-product-page-intro>
            <div class="admin-product-page-copy">
                <div class="admin-product-page-breadcrumb">
                    <a href="/admin/products">Ürünler</a>
                    <span>@pageTitle</span>
                </div>
            </div>
        </header>

        <div class="admin-product-topbar" data-product-sticky-bar>
            <div class="admin-product-tab-shell" data-product-tab-shell>
                <button type="button" class="admin-product-tab-arrow is-left" data-product-tab-arrow="left" aria-label="Sekmeleri sola kaydir">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
                <nav class="admin-product-tab-nav admin-product-tab-nav-top" data-product-tab-nav aria-label="Ürün duzenleme sekmeleri">
                    @if (isBundleMode)
                    {
                        <button type="button" class="admin-product-tab-button" data-product-tab="bundle-type">Paket Ürün Türü</button>
                    }
                    <button type="button" class="admin-product-tab-button" data-product-tab="basic">Temel Bilgi</button>
                    @if (shouldRenderVariantSection)
                    {
                        <button type="button" class="admin-product-tab-button" data-product-tab="variant" data-bundle-variant-tab @(isBundleMode && !isBundleVariantMode ? "hidden" : null)>Varyant</button>
                    }
                    @if (isBundleMode)
                    {
                        <button type="button" class="admin-product-tab-button" data-product-tab="bundle-items">Paketteki Ürünler</button>
                        <button type="button" class="admin-product-tab-button" data-product-tab="price">Fiyat</button>
                    }
                    <button type="button" class="admin-product-tab-button" data-product-tab="media">Medya</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="details">Ürün Detayi</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="inventory">Envanter</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="seo">SEO</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="features">Filtreler</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="custom-fields">Özel Alanlar</button>
                    <button type="button" class="admin-product-tab-button" data-product-tab="personalization">Ürün Özelleştirmesi</button>
                </nav>
                <button type="button" class="admin-product-tab-arrow is-right" data-product-tab-arrow="right" aria-label="Sekmeleri saga kaydir">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </div>

            <div class="admin-product-topbar-actions">
                <label class="admin-product-status-wrap" aria-label="Ürün durumu">
                    <select class="form-select auth-input" data-product-status-select>
                        @if (Model.Status == ProductPublishingStatus.Draft)
                        {
                            <option value="Draft" selected>Taslak</option>
                        }
                        else
                        {
                            <option value="Draft">Taslak</option>
                        }
                        @if (Model.Status == ProductPublishingStatus.PublishedClosed)
                        {
                            <option value="PublishedClosed" selected>Satisa Kapali Yayinla</option>
                        }
                        else
                        {
                            <option value="PublishedClosed">Satisa Kapali Yayinla</option>
                        }
                        @if (Model.Status == ProductPublishingStatus.PublishedOpen)
                        {
                            <option value="PublishedOpen" selected>Satışa Açık Yayınla</option>
                        }
                        else
                        {
                            <option value="PublishedOpen">Satışa Açık Yayınla</option>
                        }
                        @if (Model.Status == ProductPublishingStatus.Archived)
                        {
                            <option value="Archived" selected>Arsivle</option>
                        }
                        else
                        {
                            <option value="Archived">Arsivle</option>
                        }
                    </select>
                </label>

                <button type="submit" class="btn admin-editor-primary admin-product-save-button">
                    <i class="fa-solid fa-floppy-disk"></i>
                    <span>Kaydet</span>
                </button>
            </div>
        </div>

        @if (isBundleMode)
        {
            <section class="admin-editor-card admin-bundle-mode-card" data-bundle-editor data-product-tab-panel="bundle-type">
                <div class="admin-editor-section-head">
                    <div class="admin-product-inline-heading" data-inline-info-wrap>
                        <h2>Paket Ürün Türü</h2>
                        <button type="button" class="admin-product-inline-info-button" data-inline-info-toggle aria-label="Paket urun turu aciklamasini goster">
                            <span>i</span>
                        </button>
                        <div class="admin-product-inline-info-tooltip" data-inline-info-tooltip hidden>
                            <strong>Paket Ürün Türü</strong>
                            <span>Basit paket tek set mantigiyla calisir. Varyantli paket ise her kombinasyon icin farkli paket icerigi tanimlamanizi saglar.</span>
                        </div>
                    </div>
                </div>

                <div class="admin-bundle-mode-grid">
                    <button type="button" class="admin-bundle-mode-option" data-bundle-mode-option="simple">
                        <strong>Basit Paket Ürünü</strong>
                        <span>Paketinizde tek bir kombinasyon sunmak isterseniz</span>
                    </button>
                    <button type="button" class="admin-bundle-mode-option" data-bundle-mode-option="variant">
                        <strong>Varyantli Paket Ürünü</strong>
                        <span>Paketinizde alt farkli kombinasyonlar sunmak isterseniz</span>
                    </button>
                </div>
            </section>
        }

        <section class="admin-editor-card admin-product-form-card" data-product-tab-panel="basic">
            <div class="admin-editor-section-head">
                <div class="admin-product-inline-heading" data-inline-info-wrap>
                    <h2>Temel Bilgiler</h2>
                    <button type="button" class="admin-product-inline-info-button" data-inline-info-toggle aria-label="Temel bilgi aciklamasini goster">
                        <span>i</span>
                    </button>
                    <div class="admin-product-inline-info-tooltip" data-inline-info-tooltip hidden>
                        <strong>Temel Bilgiler</strong>
                        <span>Taslak disindaki durumlarda urun adi, kategori, fiyat, aciklama ve gorsel alanlari zorunludur.</span>
                    </div>
                </div>
            </div>

            <div class="admin-product-field-grid admin-product-field-grid-single">
                <input asp-for="Rating" type="hidden" />
                <input asp-for="ReviewCount" type="hidden" />

                <div class="admin-product-field-span">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control auth-input" placeholder="Orn. Clinique Nemlendirici 50 ml" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="ProductKind" class="form-label">Ürün Turu</label>
                    <select asp-for="ProductKind" class="form-select auth-input">
                        <option value="@ProductKind.Physical">Fiziksel Ürün</option>
                        <option value="@ProductKind.Digital">Dijital Ürün</option>
                        <option value="@ProductKind.Bundle">Paket Ürün</option>
                    </select>
                    <span class="admin-editor-note">Dijital urunlerde odeme akisi kargo ve adres adimlarini atlayabilir. Paket urunlerde stok ve fiyat akisi bundle alanlarindan yonetilir.</span>
                </div>

                @if (!isBundleMode)
                {
                <div>
                    <label asp-for="Price" class="form-label">Satis Fiyati</label>
                    <div class="admin-product-input-wrap">
                        <input asp-for="Price" class="form-control auth-input" type="number" min="0" step="0.01" />
                        <span>TL</span>
                    </div>
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="OldPrice" class="form-label">Indirimli Fiyat</label>
                    <div class="admin-product-input-wrap">
                        <input asp-for="OldPrice" class="form-control auth-input" type="number" min="0" step="0.01" />
                        <span>TL</span>
                    </div>
                    <span asp-validation-for="OldPrice" class="text-danger"></span>
                </div>

                <div>
                    <label asp-for="PurchasePrice" class="form-label">Alis Fiyati</label>
                    <div class="admin-product-input-wrap">
                        <input asp-for="PurchasePrice" class="form-control auth-input" type="number" min="0" step="0.01" />
                        <span>TL</span>
                    </div>
                    <span asp-validation-for="PurchasePrice" class="text-danger"></span>
                </div>
                }

                <div class="admin-product-field-span">
                    <label class="admin-product-check-row">
                        <input asp-for="ShowUnitPrice" class="form-check-input" type="checkbox" data-unit-price-toggle />
                        <span>Bu urun icin birim fiyat goster</span>
                    </label>
                </div>

                <div class="admin-product-field-span admin-product-review-summary" data-review-summary @(hasReviewSummary ? null : "hidden")>
                    <label class="form-label">Degerlendirme</label>
                    <div class="admin-product-review-stars" aria-label="@($"{Model.Rating:0.0} yildiz, {Model.ReviewCount} degerlendirme")">
                        @for (var index = 1; index <= 5; index++)
                        {
                            <span class="@(index <= roundedRating ? "is-filled" : null)">?</span>
                        }
                        <strong>@Model.Rating.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</strong>
                        <small>(@Model.ReviewCount)</small>
                    </div>
                </div>

                <div class="admin-product-field-span admin-product-unit-price-panel" data-unit-price-panel @(Model.ShowUnitPrice ? null : "hidden")>
                    <div class="admin-product-unit-price-grid">
                        <div class="admin-variant-empty-copy">
                            <label asp-for="UnitContentAmount" class="form-label">Ürünün Birim Ölçüsü</label>
                            <div class="admin-product-unit-input-row">
                                <input asp-for="UnitContentAmount" class="form-control auth-input" type="number" min="0" step="0.0001" data-unit-content-amount />
                                <select asp-for="UnitContentType" class="form-select auth-input" data-unit-content-type>
                                    <option value="">Seçiniz</option>
                                    <optgroup label="Hacim">
                                        <option value="ml">ml</option>
                                        <option value="cl">cl</option>
                                        <option value="l">l</option>
                                        <option value="m3">m3</option>
                                    </optgroup>
                                    <optgroup label="Agirlik">
                                        <option value="mg">mg</option>
                                        <option value="gr">gr</option>
                                        <option value="kg">kg</option>
                                    </optgroup>
                                    <optgroup label="Boyut">
                                        <option value="mm">mm</option>
                                        <option value="cm">cm</option>
                                        <option value="m">m</option>
                                    </optgroup>
                                    <optgroup label="Alan">
                                        <option value="m2">m2</option>
                                    </optgroup>
                                </select>
                            </div>
                            <span asp-validation-for="UnitContentAmount" class="text-danger"></span>
                            <span asp-validation-for="UnitContentType" class="text-danger"></span>
                        </div>

                        <div>
                            <label asp-for="UnitComparisonAmount" class="form-label">Satilan Birim</label>
                            <div class="admin-product-unit-input-row">
                                <input asp-for="UnitComparisonAmount" class="form-control auth-input" type="number" min="0" step="0.0001" data-unit-comparison-amount />
                                <select asp-for="UnitComparisonType" class="form-select auth-input" data-unit-comparison-type>
                                    <option value="">Seçiniz</option>
                                    <optgroup label="Hacim">
                                        <option value="ml">ml</option>
                                        <option value="cl">cl</option>
                                        <option value="l">l</option>
                                        <option value="m3">m3</option>
                                    </optgroup>
                                    <optgroup label="Agirlik">
                                        <option value="mg">mg</option>
                                        <option value="gr">gr</option>
                                        <option value="kg">kg</option>
                                    </optgroup>
                                    <optgroup label="Boyut">
                                        <option value="mm">mm</option>
                                        <option value="cm">cm</option>
                                        <option value="m">m</option>
                                    </optgroup>
                                    <optgroup label="Alan">
                                        <option value="m2">m2</option>
                                    </optgroup>
                                </select>
                            </div>
                            <span asp-validation-for="UnitComparisonAmount" class="text-danger"></span>
                            <span asp-validation-for="UnitComparisonType" class="text-danger"></span>
                        </div>

                        <div class="admin-product-unit-price-result">
                            <label class="form-label">Birim Fiyat</label>
                            <strong data-unit-price-result>-</strong>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="admin-editor-card" data-product-tab-panel="media">
            <div class="admin-editor-section-head">
                <div class="admin-product-inline-heading" data-inline-info-wrap>
                    <h2>Medya</h2>
                    <button type="button" class="admin-product-inline-info-button" data-inline-info-toggle aria-label="Medya aciklamasini goster">
                        <span>i</span>
                    </button>
                    <div class="admin-product-inline-info-tooltip" data-inline-info-tooltip hidden>
                        <strong>Medya</strong>
                        <span>Kapak gorseli urun listesinde ve detay sayfasinda ilk kare olarak kullanilir.</span>
                    </div>
                </div>
            </div>

            <div class="admin-product-media-editor admin-product-media-editor-v2"
                 data-product-gallery-editor="true"
                 data-gallery-upload-url="/admin/products/upload-image"
                 data-gallery-library-url="/admin/media/library-items"
                 data-gallery-max-items="4">
                <input asp-for="ImageUrl" type="hidden" data-gallery-cover-input />
                <textarea asp-for="GalleryImageUrls" class="d-none" data-gallery-hidden></textarea>
                <input asp-for="MediaItemsJson" type="hidden" data-gallery-items-json />
                <input type="file" class="d-none" accept="image/png,image/jpeg,image/webp,image/gif" data-gallery-file-input />

                <div class="admin-product-media-preview">
                    <button type="button" class="admin-product-media-preview-stage" data-gallery-main-trigger>
                        <img src="@Model.ImageUrl" alt="@Model.Name" data-gallery-main-preview @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "hidden" : null) />
                        <span class="admin-product-media-preview-empty" data-gallery-main-empty @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? null : "hidden")>
                            <i class="fa-solid fa-cloud-arrow-up"></i>
                            <strong>Ürün fotografini yukleyin</strong>
                            <small>Maksimum 10 MB. PNG, JPG, WEBP veya GIF kullanabilirsiniz.</small>
                        </span>
                        <span class="admin-product-media-preview-overlay">Onizle</span>
                        <span class="admin-product-media-preview-remove" data-gallery-main-remove @(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "hidden" : null)>
                            <i class="fa-solid fa-xmark"></i>
                        </span>
                    </button>

                    <div class="admin-product-media-strip" data-gallery-strip></div>
                    <div class="admin-product-media-toolbar">
                        <button type="button" class="admin-editor-secondary" data-gallery-open-library>
                            <i class="fa-solid fa-images"></i>
                            <span>Kutuphaneden Sec</span>
                        </button>
                    </div>
                    <div class="admin-product-media-help">Kapak gorseli ilk kare olur. Maksimum 4 gorsel ekleyebilirsiniz.</div>
                    <span asp-validation-for="ImageUrl" class="text-danger"></span>
                </div>
            </div>
        </section>

        <section class="admin-editor-card admin-product-step-card" data-product-tab-panel="details">
            <div class="admin-editor-section-head">
                <div class="admin-product-inline-heading" data-inline-info-wrap>
                    <h2>Ürün Detayi</h2>
                    <button type="button" class="admin-product-inline-info-button" data-inline-info-toggle aria-label="Ürün detayi aciklamasini goster">
                        <span>i</span>
                    </button>
                    <div class="admin-product-inline-info-tooltip" data-inline-info-tooltip hidden>
                        <strong>Ürün Detayi</strong>
                        <span>Görsel7-8-9 filtre altyapisini besleyecek urun siniflandirmasini burada tamamlayin.</span>
                    </div>
                </div>
            </div>

            <div class="admin-product-field-grid admin-product-field-grid-single">
                <div>
                    <label asp-for="BrandId" class="form-label"></label>
                    <select asp-for="BrandId" class="form-select auth-input">
                        <option value="">Seçiniz</option>
                        @foreach (var option in Model.BrandOptions)
                        {
                            <option value="@option.Id">@option.Name</option>
                        }
                    </select>
                    <span asp-validation-for="BrandId" class="text-danger"></span>
                </div>

                <div>
                    <label class="form-label" for="product-tag-selector-input">Etiket</label>
                    <script type="application/json" data-product-tag-options>@Html.Raw(tagSelectorPayload)</script>
                    <div class="admin-product-tag-selector" data-product-tag-selector>
                        <div class="admin-product-tag-selector-control" data-tag-selector-control>
                            <div class="admin-product-tag-selector-chips" data-tag-selector-chips>
                                @foreach (var tag in selectedTags)
                                {
                                    <span class="admin-product-tag-chip" data-tag-chip="@tag.Id">
                                        <span>@tag.Name</span>
                                        <button type="button" data-tag-remove="@tag.Id" aria-label="@($"{tag.Name} etiketini kaldir")">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </span>
                                }
                            </div>
                            <input id="product-tag-selector-input" type="text" class="admin-product-tag-selector-input" data-tag-selector-input placeholder="Etiket ara veya yeni ekle" autocomplete="off" />
