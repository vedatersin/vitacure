@model vitacure.Models.ViewModels.Admin.CategoryFormViewModel

@{
    ViewData["Title"] = "Kategori Düzenle";
}

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page auth-page-admin">
    <div class="container auth-container auth-container-wide">
        <div class="auth-card auth-card-admin">
            <div class="auth-eyebrow">Kategori Yönetimi</div>
            <h1 class="auth-title">Kategori düzenle</h1>
            <p class="auth-subtitle">Slug değişikliği storefront URL’lerini doğrudan etkiler; bu yüzden burada kontrollü ilerliyoruz.</p>

            @await Html.PartialAsync("~/Areas/Admin/Views/Categories/_Form.cshtml", Model)
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
