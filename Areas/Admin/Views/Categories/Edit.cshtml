@model vitacure.Models.ViewModels.Admin.CategoryFormViewModel

@{
    ViewData["Title"] = "Kategori Düzenle";

    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Katalog Yönetimi",
        Title = "Kategori duzenle",
        Description = "Slug degisikligi storefront URL'lerini dogrudan etkiler; bu nedenle kontrollu ilerliyoruz.",
        IconClass = "fa-solid fa-pen-to-square",
        AsideTitle = "Form akis notu",
        AsideText = "Bu ekrandaki slug, ust kategori ve aktiflik degisiklikleri storefront kategori sayfasini dogrudan etkiler.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Kayit", Value = Model.Id?.ToString() ?? "-" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Durum", Value = Model.IsActive ? "Aktif" : "Pasif" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Kategoriler", Url = "/admin/categories" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Düzenle", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)
    <section class="admin-section-card">
        @await Html.PartialAsync("~/Areas/Admin/Views/Categories/_Form.cshtml", Model)
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/pages/admin-category-form.js" asp-append-version="true"></script>
    <script src="~/js/pages/admin-richtext.js" asp-append-version="true"></script>
}
