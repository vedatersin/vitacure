@model vitacure.Models.ViewModels.Admin.CategoryFormViewModel

@{
    ViewData["Title"] = "Kategori Olustur";

    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Katalog Yonetimi",
        Title = "Yeni kategori olustur",
        Description = "Kategori eklendiginde storefront tarafinda dinamik route ile erisilebilir hale gelir.",
        IconClass = "fa-solid fa-folder-plus",
        AsideTitle = "Form akis notu",
        AsideText = "Yeni kategori kaydi, navigasyon ve route yapisinda dogrudan gorunebilir. Slug ve aktiflik alanini baslangicta dogru kurmak iyi olur.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Mod", Value = "Yeni" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Durum", Value = Model.IsActive ? "Aktif" : "Pasif" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Kategoriler", Url = "/admin/categories" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Yeni", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)
    <section class="admin-section-card">
        @await Html.PartialAsync("~/Areas/Admin/Views/Categories/_Form.cshtml", Model)
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
