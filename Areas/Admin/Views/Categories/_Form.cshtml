@model vitacure.Models.ViewModels.Admin.CategoryFormViewModel

<form method="post" class="auth-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control auth-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Slug" class="form-label"></label>
            <input asp-for="Slug" class="form-control auth-input" />
            <span asp-validation-for="Slug" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="ParentId" class="form-label"></label>
            <select asp-for="ParentId" class="form-select auth-input">
                <option value="">Yok</option>
                @foreach (var option in Model.ParentOptions)
                {
                    <option value="@option.Id">@option.Name</option>
                }
            </select>
        </div>

        <div class="col-md-6 d-flex align-items-end">
            <div class="form-check mb-2">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control auth-textarea" rows="5"></textarea>
        </div>

        <div class="col-md-6">
            <label asp-for="SeoTitle" class="form-label"></label>
            <input asp-for="SeoTitle" class="form-control auth-input" />
        </div>

        <div class="col-md-6">
            <label asp-for="MetaDescription" class="form-label"></label>
            <input asp-for="MetaDescription" class="form-control auth-input" />
        </div>
    </div>

    <div class="auth-admin-actions mt-4">
        <button type="submit" class="btn auth-submit-btn auth-secondary-btn">Kaydet</button>
        <a href="/admin/categories" class="btn auth-submit-btn auth-tertiary-btn">Listeye Dön</a>
    </div>
</form>
