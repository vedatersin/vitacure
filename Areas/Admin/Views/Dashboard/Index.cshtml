@model vitacure.Models.ViewModels.Admin.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var metricTones = new[] { "is-cyan", "is-amber", "is-rose", "is-violet", "is-teal", "is-sky" };
    var actionTones = new[] { "is-cyan", "is-amber", "is-rose", "is-violet", "is-teal", "is-sky" };
}

<div class="admin-page-grid">
    <section class="admin-section-card admin-dashboard-metrics">
        <div class="admin-section-head">
            <div>
                <div class="admin-page-eyebrow">Canli Metrikler</div>
                <h2>Sistemin mevcut durumu</h2>
                <p>Ürün, kategori, hesap, siparis ve altyapi sinyallerini tek yuzeyde toplayan yönetim katmani.</p>
            </div>
        </div>
        <div class="admin-metric-grid">
            @for (var index = 0; index < Model.Cards.Count; index++)
            {
                var card = Model.Cards[index];
                <div class="admin-metric-card @metricTones[index % metricTones.Length]">
                    <span>@card.Title</span>
                    <strong>@card.Value</strong>
                    <p>@card.Description</p>
                </div>
            }
        </div>
    </section>

    <section class="admin-actions-card admin-dashboard-actions">
        <div class="admin-section-head">
            <div>
                <div class="admin-page-eyebrow">Modüller</div>
                <h2>Yönetim alanlari</h2>
                <p>Klasik sidebarli, modüler ve tasinabilir admin tasarimina uygun olarak hizli erisim alanlarini kartlara tasidim.</p>
            </div>
        </div>
        <div class="admin-action-grid">
            <a href="/admin/orders" class="admin-action-link @actionTones[0]">
                <span>Operasyon</span>
                <strong>Siparisler</strong>
                <p>Bekleyen siparisleri, hacmi ve ciroyu izle.</p>
            </a>
            <a href="/admin/products" class="admin-action-link @actionTones[1]">
                <span>Katalog</span>
                <strong>Ürünler</strong>
                <p>Storefront kartlari ve detay kayitlari burada beslenir.</p>
            </a>
            <a href="/admin/categories" class="admin-action-link @actionTones[2]">
                <span>Yapi</span>
                <strong>Kategoriler</strong>
                <p>Slug, route ve kategori hiyerarsisi bu modülle ilerler.</p>
            </a>
            <a href="/admin/users" class="admin-action-link @actionTones[4]">
                <span>Erisim</span>
                <strong>Kullanicilar</strong>
                <p>Müşteri ve backoffice hesaplarini ayrı takip et.</p>
            </a>
            <a href="/admin/showcases" class="admin-action-link @actionTones[5]">
                <span>Storefront</span>
                <strong>Vitrinler</strong>
                <p>Landing ve ana sayfa vitrin kurgularini yönet.</p>
            </a>
        </div>
    </section>

    <section class="admin-section-card admin-dashboard-technical">
        <div class="admin-section-head">
            <div>
                <div class="admin-page-eyebrow">Teknik Izleme</div>
                <h2>Altyapi ve cache notlari</h2>
                <p>Backoffice tarafinda operasyonel sinyalleri sade ve karar verilebilir halde tutuyoruz.</p>
            </div>
        </div>
        <div class="admin-metric-grid">
            <div class="admin-metric-card is-teal">
                <span>@Model.RedisStatus.Title</span>
                <strong>@Model.RedisStatus.StatusLabel</strong>
                <p>@Model.RedisStatus.Detail</p>
            </div>
            <div class="admin-metric-card is-violet">
                <span>Output Cache</span>
                <strong>@Model.CacheMetrics.HitRateLabel hit</strong>
                <p>@Model.CacheMetrics.Detail</p>
            </div>
        </div>
    </section>
</div>
