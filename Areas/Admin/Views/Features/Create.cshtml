@model vitacure.Models.ViewModels.Admin.FeatureFormViewModel

@{
    ViewData["Title"] = "Yeni Özellik";

    var hero = new vitacure.Models.ViewModels.Admin.AdminPageHeroViewModel
    {
        Eyebrow = "Katalog Genisleme",
        Title = "Yeni Özellik olustur",
        Description = "Ürün filtreleri, detay bloklari ve ileride varyant kurallari için kullanilacak Özellik katmani burada yönetilir.",
        IconClass = "fa-solid fa-sliders",
        AsideTitle = "Form akis notu",
        AsideText = "Grup ve seçenek alanlari ne kadar tutarli olursa Ürün formundaki seçim deneyimi o kadar güçlü olur.",
        Stats = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Mod", Value = "Yeni" },
            new vitacure.Models.ViewModels.Admin.AdminHeroStatViewModel { Label = "Durum", Value = Model.IsActive ? "Aktif" : "Pasif" }
        },
        Breadcrumbs = new[]
        {
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Dashboard", Url = "/admin/dashboard" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Özellikler", Url = "/admin/features" },
            new vitacure.Models.ViewModels.Admin.AdminBreadcrumbItemViewModel { Label = "Yeni", IsActive = true }
        }
    };
}

<div class="admin-page-grid">
    @await Html.PartialAsync("~/Areas/Admin/Views/Shared/_AdminPageHero.cshtml", hero)
    <section class="admin-section-card">
        <partial name="_Form" model="Model" />
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
