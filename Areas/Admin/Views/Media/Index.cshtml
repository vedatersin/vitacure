@model vitacure.Models.ViewModels.Admin.MediaLibraryViewModel

@{
    ViewData["Title"] = "Medya K�t�phanesi";
}

<section class="admin-page-grid">
    <section class="admin-page-header-simple admin-page-header-simple-title-only">
        <h1 class="admin-page-header-simple-title">Medya k�t�phanesi</h1>
    </section>

    <div class="admin-editor-card">
        @if (Model.Items.Count == 0)
        {
            <div class="admin-media-library-empty">K�t�phane hen�z bos.</div>
        }
        else
        {
            <div class="admin-media-library-grid">
                @foreach (var item in Model.Items)
                {
                    <article class="admin-media-library-card">
                        <img src="@item.Url" alt="@(item.AltText ?? item.OriginalFileName)" />
                        <div class="admin-media-library-copy">
                            <strong>@(string.IsNullOrWhiteSpace(item.Title) ? item.OriginalFileName : item.Title)</strong>
                            <span>@item.SizeLabel</span>
                            <small>@item.CreatedAt.ToLocalTime().ToString("dd MMM yyyy HH:mm")</small>
                            <small>@item.UsageCount kullanim</small>
                        </div>
                        <form method="post" action="/admin/media/update" class="admin-media-library-form">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="Id" value="@item.Id" />
                            <input type="text" name="Title" class="form-control auth-input" value="@item.Title" placeholder="Gorunen ad" />
                            <input type="text" name="AltText" class="form-control auth-input" value="@item.AltText" placeholder="Alt text" />
                            <div class="admin-media-library-actions">
                                <button type="submit" class="admin-editor-secondary">Kaydet</button>
                            </div>
                        </form>
                        <form method="post" action="/admin/media/delete/@item.Id" class="admin-media-library-delete-form" onsubmit="return confirm('Bu medya kaydini silmek istiyor musunuz?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="admin-editor-secondary">Sil</button>
                        </form>
                    </article>
                }
            </div>
        }
    </div>
</section>
