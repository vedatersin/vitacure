@model BannerViewModel
@{
    var cardClass = !string.IsNullOrWhiteSpace(Model.Title) ? "banner-card banner-card--supplement" : "banner-card";
}

<a href="@Model.TargetUrl" class="@cardClass" style="@(string.IsNullOrWhiteSpace(Model.Gradient) ? string.Empty : $"background: {Model.Gradient};")">
    @if (!string.IsNullOrWhiteSpace(Model.Title))
    {
        <span class="popular-supplement-title" style="color:@(Model.TextColor ?? "#ffffff");">@Model.Title</span>
    }
    <img src="@Model.ImageUrl" alt="@Model.AltText" />
</a>
