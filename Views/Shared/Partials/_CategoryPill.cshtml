@model CategorySummaryViewModel

@{
    var pillLabel = Model.Slug switch
    {
        "uyku-sagligi" => "Uyku<br/>Sagligi",
        "multivitamin-enerji" => "Multivitamin<br/>& Enerji",
        "zihin-hafiza-guclendirme" => "Zihin & Hafiza<br/>G��lendirme",
        "hastaliklara-karsi-koruma" => "Hastaliklara<br/>Karsi Koruma",
        "kas-ve-iskelet-sagligi" => "Kas ve Iskelet<br/>Sagligi",
        "zayiflama-destegi" => "Zayiflama<br/>Destegi",
        _ => Model.Name
    };
}

<a href="/@Model.Slug" class="ag-category-pill @Model.PillCssClass" data-category-pill data-category-slug="@Model.Slug" data-category-name="@Model.DisplayName">
    <i class="@Model.IconClass"></i>
    <span>@Html.Raw(pillLabel)</span>
</a>
