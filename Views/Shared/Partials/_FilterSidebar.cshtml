@model IReadOnlyList<FilterGroupViewModel>

@{
    var panel = Model.FirstOrDefault();
}

<div class="filter-sidebar bg-white p-3 border rounded-3 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h6 class="fw-bold mb-0 text-dark">@(panel?.PanelTitle ?? "Filtrele")</h6>
        <a href="#" class="text-info text-decoration-none fw-semibold filter-clear-link">@(panel?.ClearLabel ?? "Temizle")</a>
    </div>

    @foreach (var filter in Model.Where(x => x.Options.Count > 0))
    {
        <div class="filter-block mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="fw-bold text-dark filter-group-title">@filter.Group</span>
                <i class="fa-solid fa-chevron-down text-muted filter-group-icon"></i>
            </div>
            @foreach (var option in filter.Options)
            {
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="@option.Id">
                    <label class="form-check-label text-muted d-flex justify-content-between w-100 filter-option-label" for="@option.Id">
                        <span>@option.Label</span><span>@option.Count</span>
                    </label>
                </div>
            }
        </div>
    }
</div>
