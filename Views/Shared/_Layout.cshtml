@using System.Text.Json
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Identity
@using vitacure.Application.Abstractions
@using vitacure.Domain.Entities
@using vitacure.Domain.Enums
@inject IAntiforgery Antiforgery
@inject UserManager<AppUser> UserManager
@inject ICustomerAccountService CustomerAccountService
@inject ICartService CartService
@inject IGuestSessionService GuestSessionService
@{
    var antiForgeryTokens = Antiforgery.GetAndStoreTokens(Context);
    IReadOnlyList<string> favoriteSlugs = Array.Empty<string>();
    var currentUser = User.Identity?.IsAuthenticated == true ? await UserManager.GetUserAsync(User) : null;
    var isCustomerUser = currentUser is not null && currentUser.AccountType == AccountType.Customer && currentUser.IsActive;
    var cartItemCount = 0;
    var favoriteCount = 0;
    if (isCustomerUser)
    {
        favoriteSlugs = await CustomerAccountService.GetFavoriteProductSlugsAsync(currentUser!.Id);
        favoriteCount = favoriteSlugs.Count;
        cartItemCount = await CartService.GetCartItemCountAsync(currentUser.Id);
    }
    else
    {
        favoriteSlugs = GuestSessionService.GetFavoriteProductSlugs();
        favoriteCount = GuestSessionService.GetFavoriteCount();
        cartItemCount = GuestSessionService.GetCartItemCount();
    }
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "VitaCure")</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "Vitacure, sağlığınıza değer veren kişiselleştirilmiş vitamin ve gıda takviyesi deneyimi sunar.")" />
    @if (ViewData["CanonicalPath"] is string canonicalPath)
    {
        <link rel="canonical" href="@($"{Context.Request.Scheme}://{Context.Request.Host}{canonicalPath}")" />
    }
    <meta name="request-verification-token" content="@antiForgeryTokens.RequestToken" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vitacure.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
@{
    var isHomePage = string.Equals(Context.Request.Path, "/", System.StringComparison.OrdinalIgnoreCase);
}
<body class="d-flex flex-column min-vh-100 @(isHomePage ? "page-home" : "page-inner")"
      data-customer-authenticated="@(isCustomerUser.ToString().ToLowerInvariant())"
      data-favorite-slugs='@JsonSerializer.Serialize(favoriteSlugs)'
      data-favorite-count="@favoriteCount"
      data-cart-item-count="@cartItemCount">
    <header class="vitacure-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent w-100 position-absolute ag-navbar" style="z-index: 1050 !important;">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" style="cursor:pointer;">
                    <img src="~/img/logo.png" alt="VitaCure Logo" style="height:38px; width:auto; object-fit:contain;">
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-medium ag-nav-links">
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="/#biz-kimiz" style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.25);">Biz Kimiz?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="/#tum-urunler" style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.25);">Tüm Ürünler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="/#kategoriler" style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.25);">Kategoriler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="/#markalar" style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.25);">Markalar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white position-relative" href="/#vitacure-ai" style="font-size: 1.1rem; font-weight: bold; text-shadow: 1px 1px 2px rgba(0,0,0,0.25);">
                                Vitacure AI
                                <span class="badge-new">yeni</span>
                            </a>
                        </li>
                    </ul>
                    <div class="ag-nav-icons ms-lg-4">
                        <a href="/account#favorites" class="text-white fs-5 nav-icon-btn no-underline position-relative" title="Favoriler" style="cursor:pointer;">
                            <i class="fa-solid fa-heart"></i>
                            <span class="cart-badge favorite-badge">@favoriteCount</span>
                        </a>
                        <a href="/cart" class="text-white fs-5 nav-icon-btn position-relative" title="Sepetim" style="cursor:pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" width="1em" height="1em" fill="currentColor" style="vertical-align:-0.125em;">
                                <path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm285-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/>
                            </svg>
                            <span class="cart-badge">@cartItemCount</span>
                        </a>
                        @if (currentUser is not null)
                        {
                            <a href="/account" class="btn btn-giris-yap" style="cursor:pointer;">Hesabım</a>
                        }
                        else
                        {
                            <a href="/login" class="btn btn-giris-yap" style="cursor:pointer;">Giriş Yap</a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main" class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="vitacure-footer" style="background: linear-gradient(135deg, #1e5e78 0%, #0d3a4d 100%); color: #cbd5e1; padding: 4rem 0 2rem 0; margin-top: auto; box-shadow: 0 -10px 30px rgba(0,0,0,0.1);">
        <div class="container" style="max-width: 1500px; width: 92%;">
            <div class="row g-4 mb-4 d-flex justify-content-between">
                <div class="col-lg-3 col-md-12 pe-lg-4">
                    <img src="~/img/logo.png" alt="VitaCure Logo" style="height: 45px; margin-bottom: 1.5rem; filter: brightness(0) invert(1);" />
                    <p style="font-size: 0.95rem; line-height: 1.6; color: #cbd5e1;">
                        Vitacure, sağlığınıza değer veren, bilim ve doğanın gücüyle tasarlanmış, kişiselleştirilmiş en kaliteli vitamin ve gıda takviyelerini sunan %100 güvenilir platformdur.
                    </p>
                </div>

                <div class="col-lg-auto col-md-4">
                    <h4 style="color: white; font-weight: 600; margin-bottom: 1.5rem; font-size: 1.2rem;">Kategoriler</h4>
                    <ul class="list-unstyled" style="line-height: 2;">
                        <li><a href="/uyku-sagligi" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Uyku Sağlığı</a></li>
                        <li><a href="/multivitamin-enerji" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Multivitamin & Enerji</a></li>
                        <li><a href="/zihin-hafiza-guclendirme" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Zihin & Hafıza Güçlendirme</a></li>
                        <li><a href="/hastaliklara-karsi-koruma" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Hastalıklara Karşı Koruma</a></li>
                        <li><a href="/kas-ve-iskelet-sagligi" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Kas ve İskelet Sağlığı</a></li>
                        <li><a href="/zayiflama-destegi" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Zayıflama Desteği</a></li>
                    </ul>
                </div>

                <div class="col-lg-auto col-md-4">
                    <h4 style="color: white; font-weight: 600; margin-bottom: 1.5rem; font-size: 1.2rem;">Hızlı Linkler</h4>
                    <ul class="list-unstyled" style="line-height: 2;">
                        <li><a href="/#biz-kimiz" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Biz Kimiz?</a></li>
                        <li><a href="/#tum-urunler" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Tüm Ürünler</a></li>
                        <li><a href="/#markalar" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Markalar</a></li>
                        <li><a href="/#vitacure-ai" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Vitacure AI</a></li>
                    </ul>
                </div>

                <div class="col-lg-auto col-md-4">
                    <h4 style="color: white; font-weight: 600; margin-bottom: 1.5rem; font-size: 1.2rem;">Kurumsal</h4>
                    <ul class="list-unstyled" style="line-height: 2;">
                        <li><a href="#" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Mesafeli Satış Sözleşmesi</a></li>
                        <li><a href="#" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">Gizlilik ve Güvenlik Politikası</a></li>
                        <li><a href="#" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">İade ve İptal Koşulları</a></li>
                        <li><a href="#" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">KVKK Aydınlatma Metni</a></li>
                        <li><a href="#" style="color: #cbd5e1; text-decoration: none; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='#cbd5e1'">İletişim</a></li>
                    </ul>
                </div>
            </div>
            <hr style="border-color: rgba(255,255,255,0.1); margin-bottom: 1.5rem;" />
            <div class="text-center" style="color: #cbd5e1; font-size: 0.9rem;">
                &copy; 2026 VitaCure. Tüm Hakları Saklıdır.
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
