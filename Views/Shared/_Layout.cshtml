<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VitaCure</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/vitacure.styles.css" asp-append-version="true" />
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Model Viewer -->
    <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/4.0.0/model-viewer.min.js"></script>
</head>
<body>
    <header class="vitacure-header">
        <nav class="navbar navbar-expand-lg navbar-dark bg-transparent w-100 position-absolute ag-navbar" style="z-index: 1050 !important;">
                <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index" style="cursor:pointer;">
                    <img src="~/img/logo.png" alt="VitaCure Logo" style="height:38px; width:auto; object-fit:contain;">
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-medium ag-nav-links">
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="#biz-kimiz">Biz Kimiz?</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="#tum-urunler">Tüm Ürünler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="#kategoriler">Kategoriler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white" href="#markalar">Markalar</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 text-white position-relative" href="#vitacure-ai">
                                Vitacure AI
                                <span class="badge-new">yeni</span>
                            </a>
                        </li>
                    </ul>
                    <div class="ag-nav-icons ms-lg-4">
                        <!-- Kalp İkonu (Solid) -->
                        <a href="#" class="text-white fs-5 nav-icon-btn no-underline" title="Favoriler" style="cursor:pointer;">
                            <i class="fa-solid fa-heart"></i>
                        </a>
                        <!-- Sepet İkonu ile Rozet (Classical Cart) -->
                        <a href="#" class="text-white fs-5 nav-icon-btn position-relative" title="Sepetim" style="cursor:pointer;">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 576 512" width="1em" height="1em" fill="currentColor" style="vertical-align:-0.125em;">
                                <path d="M0 24C0 10.7 10.7 0 24 0H69.5c22 0 41.5 12.8 50.6 32h411c26.3 0 45.5 25 38.6 50.4l-41 152.3c-8.5 31.4-37 53.3-69.5 53.3H170.7l5.4 28.5c2.2 11.3 12.1 19.5 23.6 19.5H488c13.3 0 24 10.7 24 24s-10.7 24-24 24H199.7c-34.6 0-64.3-24.6-70.7-58.5L77.4 54.5c-.7-3.8-4-6.5-7.9-6.5H24C10.7 48 0 37.3 0 24zM128 464a48 48 0 1 1 96 0 48 48 0 1 1 -96 0zm285-48a48 48 0 1 1 0 96 48 48 0 1 1 0-96z"/>
                            </svg>
                            <span class="cart-badge">0</span>
                        </a>
                        <!-- Giriş Yap Butonu -->
                        <a href="#" class="btn btn-giris-yap" style="cursor:pointer;">Giriş Yap</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
