        <script>
            let uykuCoverflowItems = [];
            let uykuCoverflowOrder = [];

            const uykuCoverflowProducts = [
                { id: 'cals-left', src: '/img/bottle_d3_nobg.png', alt: 'Kalsiyum', name: 'Kalsiyum Kompleks', description: 'Kemik ve diş sağlığını destekler. İleri yaşlarda güçlü kemik yapısını korumaya yardımcı olur.', rating: '4.7', priceNew: '₺199,00', priceOld: '₺259,00' },
                { id: 'multi-left', src: '/img/bottle_multi_nobg.png', alt: 'Multi Vitamin', name: 'Daily Multivitamin', description: 'Günlük enerji dengesini, bağışıklığı ve temel vitamin desteğini tek kapsülde tamamlamaya yardımcı olur.', rating: '4.8', priceNew: '₺299,00', priceOld: '₺399,00' },
                { id: 'omega-left', src: '/img/bottle_omega_nobg.png', alt: 'Omega 3', name: 'Omega 3', description: 'Rahat bir gece rutini için bedenin gevşemesine destek olur, zihinsel dinginlik hissini güçlendirmeye yardımcı olur.', rating: '4.9', priceNew: '₺349,00', priceOld: '₺499,00' },
                { id: 'mag-center', src: '/img/bottle_mag_nobg.png', alt: 'Magnezyum', name: 'Magnezyum', description: 'Kasların gevşemesine destek olur. Uyku öncesi rahatlamayı artırır. Gece rutininde daha sakin bir geçiş sağlar.', rating: '4.7', priceNew: '₺249,00', priceOld: '₺349,00' },
                { id: 'multi-right', src: '/img/bottle_multi_nobg.png', alt: 'C Vitamini Complex', name: 'C Vitamini Complex', description: 'Yoğun günlerde bağışıklık desteği sunarken vücudun toparlanma sürecine destek olur.', rating: '4.6', priceNew: '₺179,00', priceOld: '₺249,00' },
                { id: 'd3-right', src: '/img/bottle_d3_nobg.png', alt: 'Vitamin D3', name: 'Vitamin D3', description: 'Kemik ve kas desteği sağlarken düşük güneş maruziyetinde günlük D vitamini ihtiyacını destekler.', rating: '4.8', priceNew: '₺199,00', priceOld: '₺279,00' },
                { id: 'b12-right', src: '/img/bottle_omega_nobg.png', alt: 'B12 Vitamini', name: 'B12 Vitamini Sprey', description: 'Sinir sistemi sağlığını korur, yorgunluk ve bitkinliğin azalmasına destek olur.', rating: '4.9', priceNew: '₺149,00', priceOld: '₺199,00' }
            ];

            const uykuCoverflowSlots = [
                { x: -192, y: -98, scale: 0.74, z: 0, opacity: 1, blur: '2px' },
                { x: -128, y: -64, scale: 0.84, z: 1, opacity: 1, blur: '2px' },
                { x: -64, y: -30, scale: 0.94, z: 2, opacity: 1, blur: '2px' },
                { x: 0, y: 26, scale: 1.18, z: 5, opacity: 1, blur: '0px' },
                { x: 64, y: -30, scale: 0.94, z: 2, opacity: 1, blur: '2px' },
                { x: 128, y: -64, scale: 0.84, z: 1, opacity: 1, blur: '2px' },
                { x: 192, y: -98, scale: 0.74, z: 0, opacity: 1, blur: '2px' }
            ];

            function createUykuCoverflowItem(product) {
                const item = document.createElement('div');
                item.className = 'uyku-coverflow-item';
                item.style.position = 'absolute';
                item.style.left = '50%';
                item.style.top = '50%';
                item.style.transformOrigin = 'center center';
                item.style.transition = 'transform 420ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease, filter 420ms ease';
                item.style.willChange = 'transform, opacity, filter';

                const img = document.createElement('img');
                img.src = product.src;
                img.alt = product.alt;
                img.style.width = '250px';
                img.style.maxWidth = 'none';
                img.style.height = 'auto';
                img.style.objectFit = 'contain';
                img.style.display = 'block';
                img.style.filter = 'drop-shadow(0 18px 28px rgba(0,0,0,0.45))';

                item.appendChild(img);
                return item;
            }

            function applyUykuVShape() {
                uykuCoverflowItems.forEach((item, productIndex) => {
                    const slotIndex = uykuCoverflowOrder.indexOf(productIndex);
                    const slot = uykuCoverflowSlots[slotIndex];

                    item.style.zIndex = String(slot.z);
                    item.style.opacity = String(slot.opacity);
                    item.style.filter = `blur(${slot.blur})`;
                    item.style.transform = `translate(calc(-50% + ${slot.x}px), calc(-50% + ${slot.y}px)) scale(${slot.scale})`;
                });

                const activeProductIndex = uykuCoverflowOrder[3];
                const activeProduct = uykuCoverflowProducts[activeProductIndex];
                const productNameEl = document.getElementById('uykuCoverflowProductName');
                const productDescriptionEl = document.getElementById('uykuCoverflowProductDescription');
                const ratingStarsEl = document.getElementById('uykuCoverflowStars');
                const ratingValueEl = document.getElementById('uykuCoverflowRatingValue');
                const priceOldEl = document.getElementById('uykuCoverflowPriceOld');
                const priceNewEl = document.getElementById('uykuCoverflowPriceNew');
                const productBtnEl = document.getElementById('uykuCoverflowProductBtn');

                if (activeProduct && productNameEl && productDescriptionEl && ratingStarsEl && ratingValueEl && priceOldEl && priceNewEl && productBtnEl) {
                    productNameEl.textContent = activeProduct.name;
                    productDescriptionEl.textContent = activeProduct.description;
                    ratingStarsEl.textContent = '★★★★★';
                    ratingValueEl.textContent = `${activeProduct.rating}/5 kullanıcı puanı`;
                    priceOldEl.textContent = activeProduct.priceOld;
                    priceNewEl.textContent = activeProduct.priceNew;
                    productBtnEl.setAttribute('aria-label', `${activeProduct.name} ürününü sepete ekle`);
                }
            }

            function initUykuCoverflow() {
                const stage = document.getElementById('uykuCoverflowStage');
                if (!stage || !document.body.classList.contains('uyku-mode')) {
                    return;
                }

                if (uykuCoverflowItems.length === 0) {
                    uykuCoverflowOrder = uykuCoverflowProducts.map((_, index) => index);
                    uykuCoverflowItems = uykuCoverflowProducts.map(product => createUykuCoverflowItem(product));

                    uykuCoverflowItems.forEach(item => {
                        stage.appendChild(item);
                    });
                }

                applyUykuVShape();
            }

            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.uyku-tag-btn').forEach(function(tag, index) {
                    if (index === 0) {
                        tag.classList.add('active');
                    }

                    tag.addEventListener('click', function() {
                        document.querySelectorAll('.uyku-tag-btn').forEach(function(otherTag) {
                            otherTag.classList.remove('active');
                        });
                        tag.classList.add('active');
                    });
                });

                const prevButton = document.getElementById('uyku-coverflow-prev');
                const nextButton = document.getElementById('uyku-coverflow-next');

                if (prevButton) {
                    prevButton.addEventListener('click', function (e) {
                        e.preventDefault();
                        if (uykuCoverflowOrder.length > 0) {
                            uykuCoverflowOrder.push(uykuCoverflowOrder.shift());
                            applyUykuVShape();
                        }
                    });
                }

                if (nextButton) {
                    nextButton.addEventListener('click', function (e) {
                        e.preventDefault();
                        if (uykuCoverflowOrder.length > 0) {
                            uykuCoverflowOrder.unshift(uykuCoverflowOrder.pop());
                            applyUykuVShape();
                        }
                    });
                }

                if (document.body.classList.contains('uyku-mode')) {
                    initUykuCoverflow();
                }
            });
        </script>

