</div>

    <input type="file" id="fileUploadInput" multiple style="display: none;" accept=".pdf,.doc,.docx,.txt" />
    <input type="file" id="imageUploadInput" multiple style="display: none;" accept="image/*" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const chatInput = document.getElementById('chatInput');
            const btnFullscreen = document.getElementById('btnFullscreen');
            const btnAddFile = document.getElementById('btnAddFile');
            const chatPanel = document.querySelector('.ag-chat-panel');
            const heroElements = document.querySelectorAll('.hero-element');
            const fileList = document.getElementById('fileList');

            const btnSend = document.getElementById('btnSend');

            // --- Auto-Resize Textarea & Fullscreen Icon Visibility ---
            chatInput.addEventListener('input', function () {
                // Renk ayarı
                if (this.value.trim() !== '') {
                    btnSend.classList.add('active');
                } else {
                    btnSend.classList.remove('active');
                }
                
                // Yükseklik sıfırlaması
                this.style.height = 'auto';
                this.style.overflowY = 'hidden';
                
                let newHeight = this.scrollHeight;
                
                // max-height (90px ~ 3 satır sınırı) aşıldıysa:
                if (newHeight >= 90 && !chatPanel.classList.contains('fullscreen-mode')) {
                    this.style.overflowY = 'auto';
                    this.style.height = '90px';
                    btnFullscreen.classList.add('visible'); // scroll varsa ikonu göster
                } else {
                    // 3 satırın altındaysa (scroll yoksa) veya fullscreen modundaysa
                    this.style.height = newHeight + 'px';
                    // Sadece fullscreen değilken gizle
                    if(!chatPanel.classList.contains('fullscreen-mode')) {
                        btnFullscreen.classList.remove('visible');
                    }
                }
            });

            // Enter Key
            chatInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    if(this.value.trim() !== '') {
                        console.log('Mesaj gönderildi:', this.value);
                        this.value = '';
                        this.style.height = '40px'; // 40px min-height'a sıfırla
                        btnSend.classList.remove('active');
                        btnFullscreen.classList.remove('visible');
                    }
                }
            });

            // --- Fullscreen Toggle Logic ---
            btnFullscreen.addEventListener('click', function(e) {
                e.stopPropagation(); // Parent tıklamasını engelle
                
                chatPanel.classList.toggle('fullscreen-mode');
                const isFullscreen = chatPanel.classList.contains('fullscreen-mode');
                const icon = this.querySelector('i');
                
                if (isFullscreen) {
                    // Ekranı Modifiye Et
                    heroElements.forEach(el => el.classList.add('hidden'));
                    icon.classList.remove('fa-expand');
                    icon.classList.add('fa-compress');
                    
                    // Fullscreen ikonunu sabitle
                    this.style.opacity = "1";
                    
                    chatInput.style.maxHeight = 'calc(100vh - 180px)'; 
                    chatInput.style.overflowY = 'auto';
                    chatInput.style.height = chatInput.scrollHeight + 'px';
                    
                } else {
                    // Geri Dön
                    heroElements.forEach(el => el.classList.remove('hidden'));
                    icon.classList.remove('fa-compress');
                    icon.classList.add('fa-expand');
                    
                    this.style.opacity = ""; 
                    
                    chatInput.style.maxHeight = '68px';
                    
                    // Input tetiklemesi ile yüksekliği eski haline düzelt
                    chatInput.dispatchEvent(new Event('input'));
                }
            });

            // --- Add File Menu Toggle ---
            const addFileMenu = document.getElementById('addFileMenu');

            btnAddFile.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation(); // Eventin document'a ulaşmasını engelle
                addFileMenu.classList.toggle('show');
            });

            // Menü dışına tıklanınca kapat
            document.addEventListener('click', function(e) {
                if (addFileMenu.classList.contains('show')) {
                    // Eğer tıklanan yer menünün içi veya artı butonu değilse kapat
                    if (!addFileMenu.contains(e.target) && e.target !== btnAddFile) {
                        addFileMenu.classList.remove('show');
                    }
                }
            });

            // Seçeneklere tıklandığında menüyü kapatmak için
            const menuItems = document.querySelectorAll('.ag-add-menu-item');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                     addFileMenu.classList.remove('show');
                });
            });

            // --- Dosya / Fotoğraf Yükleme İşlemleri ---
            const fileUploadInput = document.getElementById('fileUploadInput');
            const imageUploadInput = document.getElementById('imageUploadInput');
            
            function handleFiles(files) {
                if(files.length > 0) {
                    Array.from(files).forEach(file => {
                        let fileDiv = document.createElement('div');
                        fileDiv.className = 'ag-file-item';
                        
                        // İkon Seçimi: Resim mi, Belge mi?
                        let iconClass = file.type.startsWith('image/') ? 'fa-regular fa-image' : 'fa-solid fa-file-pdf';
                        let iconColor = file.type.startsWith('image/') ? '#4285f4' : '#ff4d4f'; // Resimler için Mavi, Belgeler için Kırmızı ton
                        
                        fileDiv.innerHTML = `
                            <i class="${iconClass}" style="color: ${iconColor}"></i> 
                            <span style="font-size: 0.9rem; margin-left:5px;">${file.name}</span>
                            <button class="ag-file-remove" onclick="this.parentElement.remove()" style="background:transparent; border:none; color: rgba(255,255,255,0.5); cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
                        `;
                        fileList.appendChild(fileDiv);
                    });
                     // Tam ekranda isek margin ayarla
                    if (chatPanel.classList.contains('fullscreen-mode')) {
                        fileList.style.marginBottom = '10px';
                    }
                }
            }

            fileUploadInput.addEventListener('change', function() {
                handleFiles(this.files);
                this.value = ''; // Aynı dosyayı tekrar seçebilmek için sıfırla
            });

            imageUploadInput.addEventListener('change', function() {
                handleFiles(this.files);
                this.value = ''; // Aynı resmi tekrar seçebilmek için sıfırla
            });

            // --- Mod Değiştirme (Sohbet / Ürün Arama) ---
            const btnModeChat = document.getElementById('btnModeChat');
            const btnModeSearch = document.getElementById('btnModeSearch');
            const btnSendIcon = document.querySelector('#btnSend i');

            btnModeChat.addEventListener('click', function(e) {
                e.preventDefault();
                btnModeChat.classList.add('active');
                btnModeSearch.classList.remove('active');
                btnSendIcon.className = 'fa-solid fa-paper-plane';
                chatInput.placeholder = 'Hedefini seç, yapay zeka ile sana uygun ürünleri ve rutinleri birlikte planlayalım.';
                
                // Arama kilidini kaldır ve boyutu yeniden hesapla
                chatPanel.classList.remove('search-mode-active');
                chatInput.dispatchEvent(new Event('input'));
                chatInput.focus();
            });

            btnModeSearch.addEventListener('click', function(e) {
                e.preventDefault();
                // Eğer hali hazırda tam ekrandaysa, önce tam ekrandan çık
                if(chatPanel.classList.contains('fullscreen-mode')) {
                    btnFullscreen.click();
                }

                btnModeSearch.classList.add('active');
                btnModeChat.classList.remove('active');
                btnSendIcon.className = 'fa-solid fa-magnifying-glass';
                chatInput.placeholder = 'Katalogda aramak istediğiniz ürünü yazın...';
                
                // Arama kilidini ekle (tek satırda tut)
                chatPanel.classList.add('search-mode-active');
                chatInput.style.height = '40px'; 
                chatInput.focus();
            });

            // Focus on load
            setTimeout(() => chatInput.focus(), 100);
        });
    </script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var featuredSwiper = new Swiper('.featured-swiper', {
                slidesPerView: 1,
                spaceBetween: 10,
                loop: true,
                pagination: {
                    el: '.swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                breakpoints: {
                    640: { slidesPerView: 3, spaceBetween: 15 },
                    768: { slidesPerView: 4, spaceBetween: 15 },
                    1024: { slidesPerView: 6, spaceBetween: 15 }, /* 5 yerine 6 yapıldı ve aralık biraz kısılıp sığdırıldı */
                }
            });
        });
    </script>
}
