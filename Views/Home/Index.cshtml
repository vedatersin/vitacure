                                    <img src="~/img/@takviye.Img" alt="@takviye.Name" style="position: absolute; right: 8px; top: 0; height: 100%; width: auto; object-fit: contain; z-index: 1; filter: drop-shadow(-2px 4px 6px rgba(0,0,0,0.15));" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
                <div class="col-lg-4 text-center">
                    <a href="#vitacure-ai" class="d-block h-100" style="border-radius: 12px; overflow: hidden; box-shadow: 0 4px 10px rgba(0,0,0,0.05); transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.02)';" onmouseout="this.style.transform='scale(1)';">
                        <img src="~/img/banners/vitacureai.png" alt="Vitacure AI Banner" style="width: 100%; height: 100%; object-fit: cover; display: block;" onerror="this.src='/img/logo.png'; this.style.padding='2rem'; this.style.background='#f3f4f6';" />
                    </a>
                </div>
            </div>
        </div>
    </div>

    
    <div id="markalar" class="brands-wrapper" style="background-color: #f3f4f6; padding: 2rem 0 4rem 0;">
        <div class="container" style="max-width: 1500px; width: 92%;">
            <div class="d-flex justify-content-between align-items-center" style="margin-bottom: 30px;">
                <h2 class="featured-title mb-0">Kampanyalar</h2>
