</div>


    <input type="file" id="fileUploadInput" multiple style="display: none;" accept=".pdf,.doc,.docx,.txt" />
    <input type="file" id="imageUploadInput" multiple style="display: none;" accept="image/*" />

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            function normalizeProductId(value) {
                return (value || '')
                    .toString()
                    .trim()
                    .toLowerCase()
                    .replace(/\s+/g, '-')
                    .replace(/[^a-z0-9-]/g, '');
            }

            function getActiveCoverflowProduct() {
                return uykuCoverflowProducts[uykuCoverflowOrder[3]] || null;
            }

            function getProductFavoriteId(button) {
                if (!button) {
                    return null;
                }

                if (button.classList.contains('coverflow-heart-btn')) {
                    const activeProduct = getActiveCoverflowProduct();
                    return activeProduct ? activeProduct.id : null;
                }

                const card = button.closest('.product-glass-card');
                if (!card) {
                    return null;
                }

                let productId = button.dataset.productId || card.dataset.productId;
                if (!productId) {
                    const titleEl = card.querySelector('.product-glass-title');
                    const imageEl = card.querySelector('img');
                    productId = normalizeProductId(titleEl ? titleEl.textContent : (imageEl ? imageEl.alt : ''));
                }

                if (productId) {
                    button.dataset.productId = productId;
                    card.dataset.productId = productId;
                }

                return productId;
            }

            function syncGridHeartButtons(productId) {
                if (!productId) {
                    return;
                }

                document.querySelectorAll('.pc-heart-btn').forEach(function (button) {
                    const buttonProductId = getProductFavoriteId(button);
                    if (buttonProductId !== productId) {
                        return;
                    }

                    const icon = button.querySelector('i');
                    const isFavorite = favoriteProductIds.has(productId);
                    button.classList.toggle('active', isFavorite);
                    button.setAttribute('aria-label', isFavorite ? 'Favorilerde' : 'Favorilere ekle');
                    button.setAttribute('title', isFavorite ? 'Favorilerde' : 'Favorilere Ekle');

                    if (icon) {
                        icon.classList.toggle('fa-solid', isFavorite);
                        icon.classList.toggle('fa-regular', !isFavorite);
                    }
                });
            }

            document.querySelectorAll('.pc-heart-btn').forEach(function (button) {
                const productId = getProductFavoriteId(button);
                syncGridHeartButtons(productId);
            });

            document.addEventListener('click', function(e) {
                const heartButton = e.target.closest('.pc-heart-btn, .coverflow-heart-btn');
                if (heartButton) {
                    e.preventDefault();
                    e.stopPropagation();

                    const productId = getProductFavoriteId(heartButton);
                    if (!productId) {
                        return;
                    }

                    if (favoriteProductIds.has(productId)) {
                        favoriteProductIds.delete(productId);
                    } else {
                        favoriteProductIds.add(productId);
                    }

                    syncGridHeartButtons(productId);
                    applyUykuVShape();
                    return;
                }
                const addButton = e.target.closest('.pc-add-btn, #uykuCoverflowProductBtn');
                if (addButton) {
                    e.preventDefault();
                    e.stopPropagation();
                    if (addButton.classList.contains('processing')) return;
                    const originalHTML = addButton.innerHTML;
                    addButton.classList.add('processing');
                    addButton.classList.add('added');
                    addButton.style.width = addButton.offsetWidth + 'px';
                    addButton.innerHTML = '<i class="fa-solid fa-check"></i> Eklendi';
                    addButton.style.background = '#10b981';
                    setTimeout(() => {
                        addButton.innerHTML = originalHTML;
                        addButton.classList.remove('processing');
                        addButton.classList.remove('added');
                        addButton.style.background = '';
                        addButton.style.width = '';
                    }, 1500);
                }
            });

            const chatInput = document.getElementById('chatInput');
            const btnFullscreen = document.getElementById('btnFullscreen');
            const btnAddFile = document.getElementById('btnAddFile');
            const chatPanel = document.querySelector('.ag-chat-panel');
            const heroElements = document.querySelectorAll('.hero-element');
            const fileList = document.getElementById('fileList');

            const btnSend = document.getElementById('btnSend');

            chatInput.addEventListener('input', function () {
                if (this.value.trim() !== '') {
                    btnSend.classList.add('active');
                } else {
                    btnSend.classList.remove('active');
                }
                
                this.style.height = 'auto';
                this.style.overflowY = 'hidden';
                
                let newHeight = this.scrollHeight;
                
                if (newHeight >= 90 && !chatPanel.classList.contains('fullscreen-mode')) {
                    this.style.overflowY = 'auto';
                    this.style.height = '90px';
                    btnFullscreen.classList.add('visible'); // scroll varsa ikonu göster
                } else {
                    this.style.height = newHeight + 'px';
                    if(!chatPanel.classList.contains('fullscreen-mode')) {
                        btnFullscreen.classList.remove('visible');
                    }
                }
            });

            chatInput.addEventListener('keydown', function(e) {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    if(this.value.trim() !== '') {
                        console.log('Mesaj gönderildi:', this.value);
                        this.value = '';
                        this.style.height = '40px'; // 40px min-height'a sıfırla
                        btnSend.classList.remove('active');
                        btnFullscreen.classList.remove('visible');
                    }
                }
            });

            btnFullscreen.addEventListener('click', function(e) {
                e.stopPropagation(); // Parent tıklamasını engelle
                
                chatPanel.classList.toggle('fullscreen-mode');
                const isFullscreen = chatPanel.classList.contains('fullscreen-mode');
                const icon = this.querySelector('i');
                
                if (isFullscreen) {
                    heroElements.forEach(el => el.classList.add('hidden'));
                    icon.classList.remove('fa-expand');
                    icon.classList.add('fa-compress');
                    
                    this.style.opacity = "1";
                    
                    chatInput.style.maxHeight = 'calc(100vh - 180px)'; 
                    chatInput.style.overflowY = 'auto';
                    chatInput.style.height = chatInput.scrollHeight + 'px';
                    
                } else {
                    heroElements.forEach(el => el.classList.remove('hidden'));
                    icon.classList.remove('fa-compress');
                    icon.classList.add('fa-expand');
                    
                    this.style.opacity = ""; 
                    
                    chatInput.style.maxHeight = '68px';
                    
                    chatInput.dispatchEvent(new Event('input'));
                }
            });

            const addFileMenu = document.getElementById('addFileMenu');

            btnAddFile.addEventListener('click', function(e) {
                e.preventDefault();
                e.stopPropagation(); // Eventin document'a ulaşmasını engelle
                addFileMenu.classList.toggle('show');
            });

            document.addEventListener('click', function(e) {
                if (addFileMenu.classList.contains('show')) {
                    if (!addFileMenu.contains(e.target) && e.target !== btnAddFile) {
                        addFileMenu.classList.remove('show');
                    }
                }
            });

            const menuItems = document.querySelectorAll('.ag-add-menu-item');
            menuItems.forEach(item => {
                item.addEventListener('click', function() {
                     addFileMenu.classList.remove('show');
                });
            });

            const fileUploadInput = document.getElementById('fileUploadInput');
            const imageUploadInput = document.getElementById('imageUploadInput');
            
            function handleFiles(files) {
                if(files.length > 0) {
                    Array.from(files).forEach(file => {
                        let fileDiv = document.createElement('div');
                        fileDiv.className = 'ag-file-item';
                        
                        let iconClass = file.type.startsWith('image/') ? 'fa-regular fa-image' : 'fa-solid fa-file-pdf';
                        let iconColor = file.type.startsWith('image/') ? '#4285f4' : '#ff4d4f'; // Resimler i�in Mavi, Belgeler i�in Kirmizi ton
                        
                        fileDiv.innerHTML = `
                            <i class="${iconClass}" style="color: ${iconColor}"></i> 
                            <span style="font-size: 0.9rem; margin-left:5px;">${file.name}</span>
                            <button class="ag-file-remove" onclick="this.parentElement.remove()" style="background:transparent; border:none; color: rgba(255,255,255,0.5); cursor:pointer;"><i class="fa-solid fa-xmark"></i></button>
                        `;
                        fileList.appendChild(fileDiv);
                    });
                    if (chatPanel.classList.contains('fullscreen-mode')) {
                        fileList.style.marginBottom = '10px';
                    }
                }
            }

            fileUploadInput.addEventListener('change', function() {
                handleFiles(this.files);
                this.value = ''; // Aynı dosyayı tekrar seçebilmek için sıfırla
            });

            imageUploadInput.addEventListener('change', function() {
                handleFiles(this.files);
                this.value = ''; // Aynı resmi tekrar seçebilmek için sıfırla
            });

            const btnModeChat = document.getElementById('btnModeChat');
            const btnModeSearch = document.getElementById('btnModeSearch');
            const btnSendIcon = document.querySelector('#btnSend i');

            const categoryNames = [
                "Uyku Sağlığı", "Multivitamin ve Enerji", "Zihin ve Hafıza Güçlendirme",
                "Hastalıklara Karşı Koruma", "Kas ve İskelet Sağlığı", "Zayıflama Desteği"
            ];
            const searchCategoryFilter = document.getElementById('searchCategoryFilter');
            const searchCategoryName = document.getElementById('searchCategoryName');
            const btnRemoveSearchFilter = document.getElementById('btnRemoveSearchFilter');

            btnRemoveSearchFilter.addEventListener('click', function(e) {
                e.preventDefault();
                searchCategoryFilter.classList.add('hidden');
                lockedCatIdx = -1;
                clearCategoryActive();
                chatInput.placeholder = 'Katalogda aramak istediğiniz ürünü yazın...';
                chatInput.focus();
            });

            btnModeChat.addEventListener('click', function(e) {
                e.preventDefault();
                btnModeChat.classList.add('active');
                btnModeSearch.classList.remove('active');
                btnSendIcon.className = 'fa-solid fa-paper-plane';
                searchCategoryFilter.classList.add('hidden');
                
                chatPanel.classList.remove('search-mode-active');
                chatInput.dispatchEvent(new Event('input'));
                chatInput.focus();
                
                if (!isUserTyping && chatInput.value.trim() === '') {
                    startAnimations();
                } else {
                    chatInput.placeholder = 'Hedefini seç, yapay zeka ile sana uygun ürünleri ve rutinleri birlikte planlayalım.';
                }
            });

            btnModeSearch.addEventListener('click', function(e) {
                e.preventDefault();
                if(chatPanel.classList.contains('fullscreen-mode')) {
                    btnFullscreen.click();
                }

                btnModeSearch.classList.add('active');
                btnModeChat.classList.remove('active');
                btnSendIcon.className = 'fa-solid fa-magnifying-glass';
                
                chatPanel.classList.add('search-mode-active');
                chatInput.style.height = '40px'; 
                chatInput.focus();
                
                stopAllAnimations();

                if (lockedCatIdx !== -1) {
                    searchCategoryFilter.classList.remove('hidden');
                    searchCategoryName.innerText = categoryNames[lockedCatIdx];
                    chatInput.placeholder = 'İçinde ara...';
                } else {
                    searchCategoryFilter.classList.add('hidden');
                    clearCategoryActive();
                    chatInput.placeholder = 'Katalogda aramak istediğiniz ürünü yazın...';
                }
            });

            const placeholderCategories = [
                [
                    "Son zamanlarda uykum \u00e7ok d\u00fczensiz, ne yapabilirim?",
                    "Gece s\u0131k s\u0131k uyan\u0131yorum, \u00f6neriniz var m\u0131?",
                    "Daha kaliteli uyumak i\u00e7in ne kullanmal\u0131y\u0131m?",
                    "Sabah yorgun kalk\u0131yorum, sebebi ne olabilir?"
                ],
                [
                    "G\u00fcn i\u00e7inde \u00e7ok halsiz hissediyorum, ne \u00f6nerirsin?",
                    "Enerjimi art\u0131rmak i\u00e7in hangi vitaminleri almal\u0131y\u0131m?",
                    "Yorgunluk i\u00e7in iyi gelen takviyeler neler?",
                    "Ba\u011f\u0131\u015f\u0131kl\u0131k ve enerji i\u00e7in ne kullanabilirim?"
                ],
                [
                    "Odaklanmakta zorlan\u0131yorum, ne yapmal\u0131y\u0131m?",
                    "Haf\u0131zam\u0131 g\u00fc\u00e7lendirmek i\u00e7in ne \u00f6nerirsin?",
                    "Ders \u00e7al\u0131\u015f\u0131rken dikkatim da\u011f\u0131l\u0131yor, \u00e7\u00f6z\u00fcm var m\u0131?",
                    "Beyin performans\u0131m\u0131 art\u0131rmak istiyorum"
                ],
                [
                    "Ba\u011f\u0131\u015f\u0131kl\u0131\u011f\u0131m\u0131 g\u00fc\u00e7lendirmek istiyorum, ne \u00f6nerirsin?",
                    "S\u0131k hasta oluyorum, nas\u0131l korunabilirim?",
                    "Gripten korunmak i\u00e7in ne kullanmal\u0131y\u0131m?",
                    "Genel sa\u011fl\u0131k i\u00e7in hangi takviyeler iyi?"
                ],
                [
                    "Eklem a\u011fr\u0131lar\u0131m var, ne \u00f6nerirsin?",
                    "Kemik sa\u011fl\u0131\u011f\u0131m\u0131 korumak i\u00e7in ne yapmal\u0131y\u0131m?",
                    "Spor yap\u0131yorum, kaslar\u0131m i\u00e7in destek \u00f6nerir misin?",
                    "Bel ve diz a\u011fr\u0131lar\u0131m i\u00e7in \u00e7\u00f6z\u00fcm var m\u0131?"
                ],
                [
                    "Kilo vermek istiyorum, nereden ba\u015flamal\u0131y\u0131m?",
                    "Ya\u011f yak\u0131m\u0131n\u0131 h\u0131zland\u0131rmak i\u00e7in ne \u00f6nerirsin?",
                    "Diyet yap\u0131yorum ama sonu\u00e7 alam\u0131yorum",
                    "\u0130\u015ftah\u0131m\u0131 kontrol etmek i\u00e7in ne kullanabilirim?"
                ]
            ];
            
            let currentCatIdx = 0;
            let lockedCatIdx = -1; // -1 = döngüsel, 0-5 = spesifik kategoriye kilitli
            let isUserTyping = false;
            let globalAnimInterval = null;
            let eraseTimer, typeTimer, initTimer;
            let placeholderAnimationToken = 0;
            let shouldResumePlaceholderAnimation = false;
            const categorySelectors = ['.bg-uyku', '.bg-multi', '.bg-zihin', '.bg-koruma', '.bg-kas', '.bg-zayiflama'];

            function clearCategoryActive() {
                document.querySelectorAll('.ag-category-pill').forEach(el => el.classList.remove('active'));
            }

            function stopAllAnimations() {
                clearInterval(globalAnimInterval);
                clearTimeout(eraseTimer);
                clearTimeout(typeTimer);
                clearTimeout(initTimer);
                globalAnimInterval = null;
                placeholderAnimationToken += 1;
            }

            function typeText(text, i, cb, token) {
                if (isUserTyping || document.hidden || token !== placeholderAnimationToken) return;
                if(i < text.length) {
                    chatInput.placeholder += text.charAt(i);
                    typeTimer = setTimeout(() => typeText(text, i + 1, cb, token), 40); 
                } else if(cb) {
                    cb();
                }
            }

            function eraseText(text, i, cb, token) {
                if (isUserTyping || document.hidden || token !== placeholderAnimationToken) return;
                if(i >= 0) {
                    chatInput.placeholder = text.substring(0, i);
                    eraseTimer = setTimeout(() => eraseText(text, i - 1, cb, token), 10); 
                } else if(cb) {
                    cb();
                }
            }

            function animateNextPrompt() {
                if (isUserTyping || chatPanel.classList.contains('search-mode-active') || document.hidden) return;

                let targetIdx = lockedCatIdx !== -1 ? lockedCatIdx : currentCatIdx;
                const prompts = placeholderCategories[targetIdx];
                const selectedPrompt = prompts[Math.floor(Math.random() * prompts.length)];
                const currentText = chatInput.placeholder;
                const token = ++placeholderAnimationToken;
                
                clearCategoryActive();
                const activeEl = document.querySelector(categorySelectors[targetIdx]);
                if (activeEl && !isUserTyping) activeEl.classList.add('active');
                
                eraseText(currentText, currentText.length, () => {
                    if (isUserTyping || document.hidden || token !== placeholderAnimationToken) return;
                    chatInput.placeholder = ""; 
                    typeText(selectedPrompt, 0, () => {
                        if (lockedCatIdx === -1) {
                            currentCatIdx = (currentCatIdx + 1) % placeholderCategories.length;
                        }
                    }, token);
                }, token);
            }

            function startAnimations() {
                stopAllAnimations();
                isUserTyping = false;
                animateNextPrompt();
                globalAnimInterval = setInterval(animateNextPrompt, 6000);
            }

            initTimer = setTimeout(startAnimations, 1000);

            document.addEventListener('visibilitychange', function() {
                if (document.hidden) {
                    shouldResumePlaceholderAnimation =
                        !isUserTyping &&
                        chatInput.value.trim() === '' &&
                        !chatPanel.classList.contains('search-mode-active');
                    stopAllAnimations();
                    return;
                }

                if (shouldResumePlaceholderAnimation) {
                chatInput.placeholder = 'Hedefini seç, yapay zeka ile sana uygun ürünleri ve rutinleri birlikte planlayalım.';
                    shouldResumePlaceholderAnimation = false;
                    startAnimations();
                }
            });

            chatInput.addEventListener('input', function() {
                if (this.value !== '') {
                    isUserTyping = true;
                    stopAllAnimations();
                    if (lockedCatIdx === -1) {
                        clearCategoryActive();
                    }
                this.placeholder = "Hedefini seç, yapay zeka ile sana uygun ürünleri ve rutinleri birlikte planlayalım.";
                }
            });

            categorySelectors.forEach((selector, idx) => {
                const el = document.querySelector(selector);
                if (el) {
                    el.addEventListener('click', (e) => {
                        e.preventDefault();
                        
                        if (idx === 0) { // Uyku Sağlığı
                           document.body.classList.add('uyku-mode');
                           requestAnimationFrame(() => {
                               initUykuCoverflow();
                           });
                        } else {
                           document.body.classList.remove('uyku-mode');
                           uykuCoverflowItems = [];
                           uykuCoverflowOrder = [];
                           const uykuStage = document.getElementById('uykuCoverflowStage');
                           if (uykuStage) {
                               uykuStage.innerHTML = '';
                           }
                        }

                        const hero = document.querySelector('.ag-hero');
                        if (!hero.classList.contains('compact-mode')) {
                            hero.classList.add('compact-mode');
                            document.getElementById('activeCategoryName').innerText = categoryNames[idx];
                            
                            setTimeout(() => {
                                window.scrollTo({
                                    top: 0,
                                    behavior: 'smooth'
                                });
                            }, 50);
                        }

                        if (chatInput.value.trim() !== '') {
                            chatInput.value = '';
                            btnSend.classList.remove('active');
                            chatInput.dispatchEvent(new Event('input')); // UI resize vs. tetikler
                        }
                        lockedCatIdx = idx;
                        isUserTyping = false;
                        
                        if (chatPanel.classList.contains('search-mode-active')) {
                            clearCategoryActive();
                            el.classList.add('active');
                            searchCategoryFilter.classList.remove('hidden');
                            searchCategoryName.innerText = categoryNames[idx];
                            chatInput.placeholder = 'İçinde ara...';
                            chatInput.focus();
                        } else {
                            startAnimations();
                        }
                    });
                }
            });

            const btnBack = document.getElementById('btnBackToCats');
            if(btnBack) {
                btnBack.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    exitCategoryMode();
                });
            }

            const btnBreadcrumb = document.getElementById('btnBreadcrumbHome');
            if(btnBreadcrumb) {
                btnBreadcrumb.addEventListener('click', function(e) {
                    e.preventDefault();
                    e.stopPropagation();
                    exitCategoryMode();
                });
            }

            function exitCategoryMode() {
                const hero = document.querySelector('.ag-hero');
                hero.classList.remove('compact-mode');
                
                document.body.classList.remove('uyku-mode');

                uykuCoverflowItems = [];
                uykuCoverflowOrder = [];
                const uykuStage = document.getElementById('uykuCoverflowStage');
                if (uykuStage) {
                    uykuStage.innerHTML = '';
                }
                
                lockedCatIdx = -1;
                clearCategoryActive();
                
                if (chatInput.value.trim() === '') {
                    startAnimations();
                }
            }

            setTimeout(() => chatInput.focus(), 100);
        });
    </script>
