                @{
                    var dummyProducts = new[] {
                        new { Name="Vitamin D3 - 3 Al 2 \u00d6de", Img="bottle_d3_nobg.png", Old="279,00", New="199,00", Score="4.7", W="94%" },
                        new { Name="Omega 3 Aile Paketi", Img="bottle_omega_nobg.png", Old="499,00", New="349,00", Score="4.9", W="98%" },
                        new { Name="C Vitamini Seti", Img="bottle_multi_nobg.png", Old="249,00", New="179,00", Score="4.6", W="92%" },
                        new { Name="Magnezyum Enerji Kofre", Img="bottle_mag_nobg.png", Old="349,00", New="249,00", Score="4.3", W="86%" },
                        new { Name="Daily Multivitamin B\u00fcy\u00fck Boy", Img="bottle_multi_nobg.png", Old="399,00", New="299,00", Score="4.8", W="96%" },
                        new { Name="Kolajen ve C Vitamini", Img="bottle_d3_nobg.png", Old="299,00", New="199,00", Score="4.8", W="96%" },
                        new { Name="\u00c7inko Kompleks", Img="bottle_mag_nobg.png", Old="199,00", New="149,00", Score="4.5", W="90%" },
                        new { Name="Probiyotik Bakteri", Img="bottle_omega_nobg.png", Old="259,00", New="189,00", Score="4.7", W="94%" },
                        new { Name="B12 Vitamini Sprey", Img="bottle_multi_nobg.png", Old="189,00", New="129,00", Score="4.6", W="92%" },
                        new { Name="Demir Takviyesi", Img="bottle_d3_nobg.png", Old="239,00", New="169,00", Score="4.4", W="88%" }
