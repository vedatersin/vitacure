        <script>
            let uykuCoverflowItems = [];
            let uykuCoverflowOrder = [];
            const favoriteProductIds = new Set();
            const uykuFavoriteProductIds = favoriteProductIds;

            const uykuCoverflowProducts = [
                { id: 'cals-left', src: '/img/bottle_d3_nobg.png', alt: 'Kalsiyum', name: 'Kalsiyum Kompleks', description: 'Kemik ve di\u015f sa\u011fl\u0131\u011f\u0131n\u0131 destekler. \u0130leri ya\u015flarda g\u00fc\u00e7l\u00fc kemik yap\u0131s\u0131n\u0131 korumaya yard\u0131mc\u0131 olur.', rating: '4.7', priceNew: '\u20BA199,00', priceOld: '\u20BA259,00' },
                { id: 'multi-left', src: '/img/bottle_multi_nobg.png', alt: 'Multi Vitamin', name: 'Daily Multivitamin', description: 'G\u00fcnl\u00fck enerji dengesini, ba\u011f\u0131\u015f\u0131kl\u0131\u011f\u0131 ve temel vitamin deste\u011fini tek kaps\u00fclde tamamlamaya yard\u0131mc\u0131 olur.', rating: '4.8', priceNew: '\u20BA299,00', priceOld: '\u20BA399,00' },
                { id: 'omega-left', src: '/img/bottle_omega_nobg.png', alt: 'Omega 3', name: 'Omega 3', description: 'Rahat bir gece rutini i\u00e7in bedenin gev\u015femesine destek olur, zihinsel dinginlik hissini g\u00fc\u00e7lendirmeye yard\u0131mc\u0131 olur.', rating: '4.9', priceNew: '\u20BA349,00', priceOld: '\u20BA499,00' },
                { id: 'mag-center', src: '/img/bottle_mag_nobg.png', alt: 'Magnezyum', name: 'Magnezyum', description: 'Kaslar\u0131n gev\u015femesine destek olur. Uyku \u00f6ncesi rahatlamay\u0131 art\u0131r\u0131r. Gece rutininde daha sakin bir ge\u00e7i\u015f sa\u011flar.', rating: '4.7', priceNew: '\u20BA249,00', priceOld: '\u20BA349,00' },
                { id: 'multi-right', src: '/img/bottle_multi_nobg.png', alt: 'C Vitamini Complex', name: 'C Vitamini Complex', description: 'Yo\u011fun g\u00fcnlerde ba\u011f\u0131\u015f\u0131kl\u0131k deste\u011fi sunarken v\u00fccudun toparlanma s\u00fcrecine destek olur.', rating: '4.6', priceNew: '\u20BA179,00', priceOld: '\u20BA249,00' },
                { id: 'd3-right', src: '/img/bottle_d3_nobg.png', alt: 'Vitamin D3', name: 'Vitamin D3', description: 'Kemik ve kas deste\u011fi sa\u011flarken d\u00fc\u015f\u00fck g\u00fcne\u015f maruziyetinde g\u00fcnl\u00fck D vitamini ihtiyac\u0131n\u0131 destekler.', rating: '4.8', priceNew: '\u20BA199,00', priceOld: '\u20BA279,00' },
                { id: 'b12-right', src: '/img/bottle_omega_nobg.png', alt: 'B12 Vitamini', name: 'B12 Vitamini Sprey', description: 'Sinir sistemi sa\u011fl\u0131\u011f\u0131n\u0131 korur, yorgunluk ve bitkinli\u011fin azalmas\u0131na destek olur.', rating: '4.9', priceNew: '\u20BA149,00', priceOld: '\u20BA199,00' }
            ];

            const uykuCoverflowSlots = [
                { x: -252, y: -118, scale: 0.72, z: 0, opacity: 1, blur: '3px' },
                { x: -168, y: -78, scale: 0.83, z: 1, opacity: 1, blur: '3px' },
                { x: -84, y: -34, scale: 0.94, z: 2, opacity: 1, blur: '3px' },
                { x: 0, y: 26, scale: 1.18, z: 5, opacity: 1, blur: '0px' },
                { x: 84, y: -34, scale: 0.94, z: 2, opacity: 1, blur: '3px' },
                { x: 168, y: -78, scale: 0.83, z: 1, opacity: 1, blur: '3px' },
                { x: 252, y: -118, scale: 0.72, z: 0, opacity: 1, blur: '3px' }
            ];

            function createUykuCoverflowItem(product) {
                const item = document.createElement('div');
                item.className = 'uyku-coverflow-item';
                item.style.position = 'absolute';
                item.style.left = '50%';
                item.style.top = '50%';
                item.style.transformOrigin = 'center center';
                item.style.transition = 'transform 420ms cubic-bezier(0.22, 1, 0.36, 1), opacity 320ms ease, filter 420ms ease';
                item.style.willChange = 'transform, opacity, filter';

                const img = document.createElement('img');
                img.src = product.src;
                img.alt = product.alt;
                img.style.width = '250px';
                img.style.maxWidth = 'none';
                img.style.height = 'auto';
                img.style.objectFit = 'contain';
                img.style.display = 'block';
                img.style.filter = 'drop-shadow(0 18px 28px rgba(0,0,0,0.45))';

                item.appendChild(img);
                return item;
            }

            function applyUykuVShape() {
                uykuCoverflowItems.forEach((item, productIndex) => {
                    const slotIndex = uykuCoverflowOrder.indexOf(productIndex);
                    const slot = uykuCoverflowSlots[slotIndex];

                    item.style.zIndex = String(slot.z);
                    item.style.opacity = String(slot.opacity);
                    item.style.filter = `blur(${slot.blur})`;
                    item.style.transform = `translate(calc(-50% + ${slot.x}px), calc(-50% + ${slot.y}px)) scale(${slot.scale})`;
                });

                const activeProductIndex = uykuCoverflowOrder[3];
                const activeProduct = uykuCoverflowProducts[activeProductIndex];
                const productNameEl = document.getElementById('uykuCoverflowProductName');
                const productDescriptionEl = document.getElementById('uykuCoverflowProductDescription');
                const ratingStarsEl = document.getElementById('uykuCoverflowStars');
                const ratingValueEl = document.getElementById('uykuCoverflowRatingValue');
                const priceOldEl = document.getElementById('uykuCoverflowPriceOld');
                const priceNewEl = document.getElementById('uykuCoverflowPriceNew');
                const productBtnEl = document.getElementById('uykuCoverflowProductBtn');
                const heartBtnEl = document.getElementById('uykuCoverflowHeartBtn');
                const heartIconEl = heartBtnEl ? heartBtnEl.querySelector('i') : null;

                if (activeProduct && productNameEl && productDescriptionEl && ratingStarsEl && ratingValueEl && priceOldEl && priceNewEl && productBtnEl) {
                    productNameEl.textContent = activeProduct.name;
                    productDescriptionEl.textContent = activeProduct.description;
                    ratingStarsEl.textContent = '\u2605\u2605\u2605\u2605\u2605';
                    ratingValueEl.textContent = `${activeProduct.rating}/5 kullan\u0131c\u0131 puan\u0131`;
                    priceOldEl.textContent = activeProduct.priceOld;
                    priceNewEl.textContent = activeProduct.priceNew;
                    productBtnEl.setAttribute('aria-label', `${activeProduct.name} \u00fcr\u00fcn\u00fcn\u00fc sepete ekle`);
                    if (heartBtnEl && heartIconEl) {
                        const isFavorite = uykuFavoriteProductIds.has(activeProduct.id);
                        heartBtnEl.classList.toggle('active', isFavorite);
                        heartIconEl.classList.toggle('fa-solid', isFavorite);
                        heartIconEl.classList.toggle('fa-regular', !isFavorite);
                        heartBtnEl.setAttribute('aria-label', isFavorite ? `${activeProduct.name} favorilerde` : `${activeProduct.name} favorilere ekle`);
                    }
                }
            }

            function initUykuCoverflow() {
                const stage = document.getElementById('uykuCoverflowStage');
                if (!stage || !document.body.classList.contains('uyku-mode')) {
                    return;
                }

                if (uykuCoverflowItems.length === 0) {
                    uykuCoverflowOrder = uykuCoverflowProducts.map((_, index) => index);
                    uykuCoverflowItems = uykuCoverflowProducts.map(product => createUykuCoverflowItem(product));

                    uykuCoverflowItems.forEach(item => {
                        stage.appendChild(item);
                    });
                }

                applyUykuVShape();
            }

            document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.uyku-tag-btn').forEach(function(tag, index) {
                    if (index === 0) {
                        tag.classList.add('active');
                    }

                    tag.addEventListener('click', function() {
                        document.querySelectorAll('.uyku-tag-btn').forEach(function(otherTag) {
                            otherTag.classList.remove('active');
                        });
                        tag.classList.add('active');
                    });
                });

                const prevButton = document.getElementById('uyku-coverflow-prev');
                const nextButton = document.getElementById('uyku-coverflow-next');

                if (prevButton) {
                    prevButton.addEventListener('click', function (e) {
                        e.preventDefault();
                        if (uykuCoverflowOrder.length > 0) {
                            uykuCoverflowOrder.push(uykuCoverflowOrder.shift());
                            applyUykuVShape();
                        }
                    });
                }

                if (nextButton) {
                    nextButton.addEventListener('click', function (e) {
                        e.preventDefault();
                        if (uykuCoverflowOrder.length > 0) {
                            uykuCoverflowOrder.unshift(uykuCoverflowOrder.pop());
                            applyUykuVShape();
                        }
                    });
                }

                if (document.body.classList.contains('uyku-mode')) {
                    initUykuCoverflow();
                }
            });
        </script>

        
