@{
    ViewData["Title"] = "Ana Sayfa";
}


<!-- Custom Styles for Home Page -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
<style>
    /* Antigravity Header Styles */
    body {
        margin: 0;
        padding: 0;
        background-color: #f8f9fa;
        overflow-x: hidden;
    }

    .hero-gradient-wrapper {
        /* Okyanus Ferahlığı (Teal-Cyan-Dark Blue) */
        background: radial-gradient(circle at top center, #5abcb5 0%, #2f94b5 50%, #17546e 100%);
    }
    /* === KATEGORİ ÖZEL SAYFA MODU === */
    body.uyku-mode .container-fluid.p-0 > div:not(.hero-gradient-wrapper):not(#uykuCategoryPage) {
        display: none !important;
    }

    body.uyku-mode #uykuCategoryPage {
        display: block !important;
    }
    
    body.uyku-mode .ag-navbar {
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        background-color: rgba(0, 0, 0, 0.15) !important; 
        backdrop-filter: blur(12px) !important;
        -webkit-backdrop-filter: blur(12px) !important;
        border-bottom: 1px solid rgba(255,255,255,0.05) !important;
        padding-top: 10px;
        padding-bottom: 5px;
        z-index: 1050;
    }
    
    body.uyku-mode .hero-gradient-wrapper {
        background: transparent !important; 
        display: block !important;
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
        width: 100% !important;
        z-index: 20 !important;
        padding-bottom: 0 !important;
        box-shadow: none !important;
    }

    body.uyku-mode .ag-title,
    body.uyku-mode .ag-subtitle,
    body.uyku-mode .ag-top-categories {
        display: none !important;
    }

    body.uyku-mode .ag-hero.compact-mode {
        height: auto !important;
        padding-top: 0 !important;
        padding-bottom: 0 !important;
    }

    /* SİYAH TRANSPARAN chat arayüzü, banner üzerine float edilecek */
    body.uyku-mode .ag-chat-panel {
        position: relative !important;
        top: 0 !important;
        left: 50% !important;
        transform: translateX(-50%) !important;
        width: 92% !important;
        max-width: 1500px !important;
        margin-top: 100px !important; /* Menüyle üst üste binmemesi için artırıldı */
        margin-bottom: 0 !important;
        background: rgba(20, 20, 30, 0.75) !important;
        border-radius: 24px !important;
        border: 1px solid rgba(255,255,255,0.15) !important;
        backdrop-filter: blur(15px) !important;
        -webkit-backdrop-filter: blur(15px) !important;
        box-shadow: 0 15px 35px rgba(0,0,0,0.3) !important;
    }
    
    body.uyku-mode .ag-chat-header {
        /* Kendi doğal border ve padding değerlerini kullansın */
    }
    
    .hide-featured {
        display: none !important;
    }
    
    /* === Vitamin & Molecule Network Background === */
    .vitamin-network-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        z-index: 1; /* Ag-Title ve Ag-Chat'in (z-index: 10) arkasında kalacak */
        pointer-events: none; /* Üzerine tıklanmasını engelle */
    }
    .ag-hero {
        position: relative;
        width: 100%;
        height: calc(80vh - 150px);
        background: transparent;
        overflow: visible;
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* General Positions (Percentage based on 100% width/height of Hero) */
    .ag-title {
        position: absolute;
        top: calc(22% - 20px); /* 10px aşağı kaydırıldı (üst boşluk için) */
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 4rem;
        font-weight: 700;
        letter-spacing: 2px;
        z-index: 10;
        text-shadow: 0 4px 20px rgba(0,0,0,0.3);
    }

    .ag-subtitle {
        position: absolute;
        top: calc(22% + 65px); /* 10px yukarı çekildi (başlığa yaklaşması için) */
        left: 50%;
        transform: translate(-50%, -50%);
        color: rgba(255, 255, 255, 0.9);
        font-size: 2.1rem;
        font-weight: 500;
        z-index: 10;
        white-space: nowrap;
        text-shadow: 0 2px 10px rgba(0,0,0,0.2);
    }

    /* Kategori Butonları (Chat panelinin dış ve üst kısmı) */
    .ag-top-categories {
        position: absolute;
        bottom: 100%; /* Panel'in tam üstüne yerleştir */
        left: 0;
        width: 100%;
        display: flex;
        gap: 12px;
        margin-bottom: 20px; /* Form ile butonlar arasına makul boşluk eklendi */
        justify-content: space-between;
    }

    .ag-category-pill {
        position: relative; /* İkonu absolute konumlandırmak için eklendi */
        flex: 1; /* Hepsi eşit genişlikte yayılsın */
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 30px 10px 15px 10px; /* Buton hacmi %25 oranında büyütüldü */
        border-radius: 20px;
        color: white;
        text-align: center;
        text-decoration: none;
        transition: all 0.3s ease;
        background: rgba(255, 255, 255, 0.18); /* Opaklık orta seviyeye (0.18) ayarlandı */
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        cursor: pointer;
        margin-top: 25px; /* İkon taşması için yukarıdan margin verildi */
    }

    .ag-category-pill:hover {
        background: rgba(255, 255, 255, 0.26); 
        box-shadow: 0 8px 15px rgba(255, 255, 255, 0.18);
        transform: translateY(-5px);
    }

    .ag-category-pill.active {
        background: rgba(255, 255, 255, 0.32); /* Aktif kart %15 daha parlak */
        box-shadow: 0 4px 15px rgba(255, 255, 255, 0.22);
    }

    .ag-category-pill.active:hover {
        background: rgba(255, 255, 255, 0.35);
    }

    .ag-category-pill i {
        font-size: 3.1rem; /* İkon boyutu ~%25 büyütüldü (2.5 -> 3.1) */
        position: absolute;
        top: -25px; /* Daha büyük ikona oranlı taşma */
        left: 50%;
        transform: translateX(-50%);
        filter: drop-shadow(0 4px 6px rgba(0,0,0,0.1)); /* İkona hafif gölge eklendi */
        z-index: 10;
    }

    .ag-category-pill span {
        font-size: 1.2rem; /* Yazı boyutu %25 daha büyütüldü (0.96 * 1.25) */
        font-weight: 700; /* Çok daha belirgin ve kalınlaştırıldı */
        line-height: 1.2;
        text-shadow: 1px 1px 4px rgba(0,0,0,0.5);
    }

    /* Kategori İkon Renkleri */
    .bg-uyku i { color: #1e3a8a; } /* Lacivert */
    .bg-multi i { color: #fba91c; }
    .bg-zihin i { color: #d67aff; }
    .bg-koruma i { color: #0f766e; } /* Daha koyu teal/yeşim */
    .bg-kas i { color: #ff5e79; }

    /* Gemini-Style Chat Interface Updates */
    .ag-chat-panel {
        position: absolute;
        top: calc(61% + 90px); /* Üstteki kaymalardan dolayı +20px aşağı alındı */
        left: 50%;
        transform: translate(-50%, -50%);
        width: 70%;
        min-height: 100px;
        background: rgba(35, 40, 48, 0.42);
        backdrop-filter: blur(25px);
        -webkit-backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 30px;
        padding: 24px 24px;
        z-index: 1040;
        box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        display: flex;
        flex-direction: column;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    /* Tam Ekran Modu (Fixed kullanarak sayfaya göre yay) */
    .ag-chat-panel.fullscreen-mode {
        position: fixed !important;
        top: 80px !important; /* Menü Çizgisinin Altından Başla */
        left: 50% !important;
        transform: translateX(-50%) !important;
        height: calc(100vh - 100px) !important; /* Alta kadar esne, hafif boşluk bırak */
        width: 90% !important;
        max-width: 1200px;
        border-radius: 20px;
        background: rgba(35, 40, 48, 0.85);
    }

    /* Üst Bölüm: Textarea + Fullscreen Butonu */
    .ag-chat-top {
        position: relative;
        width: 100%;
        display: flex;
        align-items: flex-start;
        margin-bottom: 12px; /* Alt araç çubuğu ile dengeli boşluk */
    }

    .ag-chat-input {
        box-sizing: border-box;
        background: transparent;
        border: none;
        color: rgba(226, 232, 240, 0.9); /* Saf beyaz çok sert olduğu için placeholder'a yakınlaştırıldı */
        font-size: 1.7rem; /* %15 küçültüldü (2.0 -> 1.7) */
        font-weight: 500;
        letter-spacing: 0.5px;
        line-height: 1.4;
        width: 100%;
        flex-grow: 1;
        resize: none;
        outline: none;
        padding-top: 2px; /* Yukarıdan (top) ekstra boşluk */
        padding-bottom: 2px;
        padding-left: 10px;
        padding-right: 48px;
        margin-bottom: 0;
        font-family: inherit;
        min-height: 110px; /* Bir satır daha genişletildi (70 -> 110) */
        max-height: 180px;
        overflow-y: hidden;
    }
    
    .ag-chat-input::-webkit-scrollbar {
        width: 6px;
    }
    .ag-chat-input::-webkit-scrollbar-track {
        background: transparent;
        margin-top: 40px; /* Fullscreen butonunu ezmemesi için track'ı 40px aşağıdan başlat */
        margin-bottom: 5px;
    }
    .ag-chat-input::-webkit-scrollbar-thumb {
        background: rgba(255,255,255,0.2);
        border-radius: 10px;
    }
    .ag-chat-input::-webkit-scrollbar-thumb:hover {
        background: rgba(255,255,255,0.4);
    }

    .ag-chat-input::placeholder {
        color: rgba(226, 232, 240, 0.6);
    }

    .ag-search-filter {
        display: flex;
        align-items: center;
        gap: 8px;
        background: rgba(255, 255, 255, 0.15);
        color: white;
        padding: 7px 14px;
        border-radius: 20px;
        font-size: 1.15rem;
        font-weight: 500;
        margin-right: 10px;
        margin-top: 4px;
        white-space: nowrap;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }
    .ag-search-filter.hidden {
        display: none !important;
    }
    .ag-search-filter-close {
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.6);
        cursor: pointer;
        padding: 0;
        font-size: 1.1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: color 0.2s;
    }
    .ag-search-filter-close:hover {
        color: #ff4d4f;
    }

    /* Fullscreen ikonu textarea'nın sağında, scrollbar ile aynı hizada */
    .btn-fullscreen {
        position: absolute;
        top: 0; /* Chat panelinin veya textarea üstünün tam hizasına */
        right: 0px; /* En sağa dayalı, böylece gönder butonuyla aynı sütuna denk gelir */
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.6);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        opacity: 0;         /* Varsayılan olarak kapalı */
        pointer-events: none;
        font-size: 0.95rem;
    }

    .btn-fullscreen.visible {
        opacity: 1;
        pointer-events: auto;
    }

    .btn-fullscreen:hover {
        background: rgba(255,255,255,0.1);
        color: white;
    }

    /* Alt Bölüm: Extralar + Gönder Butonu */
    .ag-chat-bottom {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        margin-top: auto; /* Fullscreen'de en alta yapışması için */
    }

    .ag-chat-actions-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .ag-btn-add {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.8);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .ag-btn-add:hover {
        background: rgba(255, 255, 255, 0.15);
        color: white;
    }

    /* Add File Dropdown Menu */
    .ag-chat-actions-left {
        position: relative; /* Menüyü butona göre hizalamak için */
    }

    .ag-add-file-menu {
        position: absolute;
        top: 120%; /* Butonun altında */
        left: 0;
        background: #1e1e20; /* Koyu gri Gemini stili */
        border-radius: 12px;
        padding: 8px 0;
        min-width: 220px;
        display: flex;
        flex-direction: column;
        box-shadow: 0 8px 24px rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.08); /* İnce sınır */
        z-index: 1000;
        
        /* Animasyon başlangıç noktası (Yukarıdan aşağı) */
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.2s cubic-bezier(0.2, 0, 0, 1);
    }

    .ag-add-file-menu.show {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .ag-add-menu-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 10px 16px;
        color: rgba(255,255,255,0.85); /* Hafif kırık beyaz */
        font-size: 0.95rem;
        cursor: pointer;
        transition: background 0.1s ease;
        text-decoration: none;
    }

    .ag-add-menu-item:hover {
        background: rgba(255, 255, 255, 0.08); /* Hover'da hafif aydınlatma */
    }

    .ag-add-menu-item i {
        font-size: 1.1rem;
        color: rgba(255,255,255,0.7);
        width: 20px;
        text-align: center;
    }

    .ag-btn-send {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.4); /* Normalde soluk */
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s ease;
        flex-shrink: 0;
        font-size: 1.1rem;
    }

    .ag-btn-send.active {
        color: white; /* İçi doluysa parlak */
        background: rgba(255,255,255,0.1); /* Opsiyonel hafif arka plan */
    }

    /* Mod Seçici Butonları (Sohbet / Ürün Arama) */
    .ag-mode-toggles {
        display: flex;
        align-items: center;
        gap: 5px;
        margin-left: 5px;
    }

    .ag-mode-btn {
        background: transparent;
        border: none;
        color: rgba(255,255,255,0.5);
        padding: 10px 18px; 
        border-radius: 25px;
        font-size: 1.25rem; 
        font-weight: 600; 
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: all 0.2s ease;
    }

    .ag-mode-btn i {
        font-size: 1.35rem;
    }

    .ag-mode-btn.active {
        background: rgba(255,255,255,0.12);
        color: white;
    }

    .ag-mode-btn:hover:not(.active) {
        background: rgba(255,255,255,0.06);
        color: rgba(255,255,255,0.8);
    }

    .uyku-tag-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        padding-bottom: 60px;
    }

    .uyku-tag-btn {
        appearance: none !important;
        -webkit-appearance: none !important;
        background: transparent !important;
        border: none !important;
        color: rgba(255,255,255,0.5) !important;
        padding: 10px 18px !important;
        border-radius: 25px !important;
        font-size: 1.15rem !important;
        font-weight: 600 !important;
        cursor: pointer !important;
        display: inline-flex !important;
        align-items: center !important;
        gap: 10px !important;
        transition: all 0.2s ease !important;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.18) !important;
        backdrop-filter: blur(8px) !important;
        -webkit-backdrop-filter: blur(8px) !important;
        text-decoration: none !important;
        line-height: 1.2 !important;
    }

    .uyku-tag-btn i {
        font-size: 1.1rem;
    }

    .uyku-tag-btn:hover,
    .uyku-tag-btn.active {
        background: rgba(255,255,255,0.12) !important;
        color: white !important;
        box-shadow: inset 0 0 0 1px rgba(255,255,255,0.08) !important;
    }
    
    /* Arama Modu Aktifken Uygulanacak Kısıtlamalar */
    .ag-chat-panel.search-mode-active .ag-chat-input {
        max-height: 40px !important; /* Hiçbir zaman büyümez */
        overflow-y: hidden !important;
        white-space: nowrap; /* Tek satıra zorla */
    }

    .ag-chat-panel.search-mode-active .btn-fullscreen {
        display: none !important; /* Arama modunda tam ekran olmaz */
    }

    /* Yüklenen dosyaların listeleneceği alan */
    .ag-file-list:empty {
        display: none; /* Boşken görünmesi ve margin itmesi engellendi */
    }
    .ag-file-list {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 12px;
        width: 100%;
    }
    .ag-file-item {
        background: rgba(255,255,255,0.1);
        border-radius: 8px;
        padding: 8px 12px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.85rem;
        color: white;
    }
    .ag-file-item i {
        color: #ef4444; /* PDF kırmızı vs */
    }
    
    /* Fullscreen olunca gizlenecek öğeler */
    .hero-element.hidden {
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .hero-element {
        transition: opacity 0.3s ease;
    }

    .ag-categories {
        position: absolute;
        top: 72%; /* Aşağı Kaydırıldı */
        left: 50%;
        transform: translateX(-50%);
        width: 92%; /* Her iki alan 92% ile eşitlendi */
        max-width: 1500px; /* Maksimum büyüklük eşitlendi */
        z-index: 10;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .ag-cat-row {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .ag-cat-btn {
        background: rgba(255, 255, 255, 0.15);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 20px;
        padding: 0.8rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        color: white;
        font-weight: 500;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        text-decoration: none;
        box-shadow: 0 8px 32px rgba(0,0,0,0.1), inset 0 0 10px rgba(255,255,255,0.1);
    }

    .ag-cat-btn:hover {
        background: rgba(255, 255, 255, 0.25);
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.15), inset 0 0 15px rgba(255,255,255,0.2);
    }

    .ag-cat-btn i {
        font-size: 1.4rem;
        /* filter: drop-shadow(0 0 5px currentColor); - Neon parlama kaldırıldı */
    }

    /* Renk tonları biraz daha koyulaştırıldı */
    .icon-moon { color: #d63384; }
    .icon-atom { color: #d97706; }
    .icon-brain { color: #be185d; }
    .icon-shield { color: #059669; }
    .icon-bone { color: #e11d48; }

    /* Stars removed as per user request */

    /* Category Blocks */
    .category-section {
        padding: 5rem 2rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    @@media (min-width: 992px) {
        .category-section {
            padding: 6rem 5rem;
        }
    }

    /* Backgrounds matching the image */
    .bg-zihin-hafiza {
        background: linear-gradient(135deg, #fceb99 0%, #ecd075 100%);
    }

    .bg-cilt-bakimi {
        background: linear-gradient(135deg, #ffdfc4 0%, #b9e9d6 100%);
    }

    .bg-uyku-sagligi {
        background: linear-gradient(135deg, #1c3666 0%, #9084d4 100%);
    }

    .bg-hastalik-koruma {
        background: linear-gradient(135deg, #c3f2d1 0%, #95d3e0 100%);
    }

    .category-title {
        font-weight: 800;
        font-size: 3rem; /* %20 büyütüldü (2.5 -> 3) */
        margin-bottom: 1.5rem;
    }

    .dark-text {
        color: #1a202c;
    }

    .light-text {
        color: white;
    }

    .feature-list-clean {
        list-style: none;
        padding-left: 0;
        margin-bottom: 2rem;
    }

    .feature-list-clean li {
        font-size: 1.1rem;
        margin-bottom: 0.8rem;
        display: flex;
        align-items: center;
        font-weight: 500;
    }

    .feature-list-clean li::before {
        content: "•";
        font-size: 1.5rem;
        margin-right: 0.5rem;
        line-height: 1;
    }

    /* Product Cards inside categories */
    .product-card {
        background: white;
        border-radius: 15px;
        padding: 1.5rem;
        text-align: center;
        height: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
        transition: transform 0.3s ease;
        text-decoration: none;
        color: inherit;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .product-card:hover {
        transform: translateY(-5px);
        color: inherit;
    }

    .product-icon-wrapper {
        width: 100px;
        height: 100px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
    }

    .bg-icon-blue { background-color: #e6f0ff; color: #4a90e2; }
