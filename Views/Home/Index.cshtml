                                <button class="pc-heart-btn" title="Favorilere Ekle" onclick="event.preventDefault()"><i class="fa-regular fa-heart"></i></button>
                            </div>
                            <div class="product-glass-body">
                                <h3 class="product-glass-title">@p.Name</h3>
                                <div class="pc-stars-row">
                                    <div class="pc-stars-wrapper"><div class="pc-stars-empty">&#9733;&#9733;&#9733;&#9733;&#9733;</div><div class="pc-stars-filled" style="width: @p.W;">&#9733;&#9733;&#9733;&#9733;&#9733;</div></div><span class="score">(@p.Score)</span>
                                </div>
