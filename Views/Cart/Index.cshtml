@model vitacure.Models.ViewModels.Cart.CartViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/pages/cart.css" asp-append-version="true" />
}

<div class="cart-page">
    <div class="container section-container">
        <div class="cart-page-header">
            <h1>Sepetim</h1>
            <p>Eklediginiz urunleri burada gorebilir, miktarlarini guncelleyebilir ve siparis adimina hazirlanabilirsiniz.</p>
        </div>

        @if (TempData["CheckoutMessage"] is string checkoutMessage)
        {
            <div class="alert @(string.Equals(TempData["CheckoutMessageType"] as string, "success", StringComparison.OrdinalIgnoreCase) ? "alert-success" : "alert-warning") cart-feedback">
                @checkoutMessage
            </div>
        }

        @if (Model.IsEmpty)
        {
            <div class="cart-empty-state">
                <h2>Sepetiniz su an bos</h2>
                <p>Begendiginiz urunleri sepete eklediginizde burada listelenecek.</p>
                <a href="/" class="btn btn-primary cart-continue-btn">Urunleri Kesfet</a>
            </div>
        }
        else
        {
            <div class="row g-4 align-items-start">
                <div class="col-lg-8">
                    <div class="cart-items-panel">
                        @foreach (var item in Model.Items)
                        {
                            <article class="cart-item-card">
                                <a href="@item.ProductHref" class="cart-item-media">
                                    <img src="@item.ProductImageUrl" alt="@item.ProductName" loading="lazy" />
                                </a>
                                <div class="cart-item-content">
                                    <div class="cart-item-copy">
                                        <a href="@item.ProductHref" class="cart-item-title">@item.ProductName</a>
                                        <div class="cart-item-unit-price">Birim fiyat: &#8378; @item.UnitPrice</div>
                                    </div>
                                    <div class="cart-item-actions">
                                        <form method="post" action="/cart/items/@item.ProductSlug/quantity" class="cart-quantity-form">
                                            @Html.AntiForgeryToken()
                                            <label class="cart-quantity-label" for="qty-@item.ProductSlug">Adet</label>
                                            <input id="qty-@item.ProductSlug"
                                                   name="quantity"
                                                   type="number"
                                                   min="1"
                                                   value="@item.Quantity"
                                                   class="form-control cart-quantity-input" />
                                            <button type="submit" class="btn btn-outline-secondary cart-update-btn">Guncelle</button>
                                        </form>
                                        <div class="cart-item-total">&#8378; @item.LineTotal</div>
                                        <form method="post" action="/cart/items/@item.ProductSlug/remove">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-link cart-remove-btn">Kaldir</button>
                                        </form>
                                    </div>
                                </div>
                            </article>
                        }
                    </div>
                </div>

                <div class="col-lg-4">
                    <aside class="cart-summary-card">
                        <h2>Siparis Ozeti</h2>
                        <div class="cart-summary-row">
                            <span>Toplam urun</span>
                            <strong>@Model.TotalQuantity</strong>
                        </div>
                        <div class="cart-summary-row">
                            <span>Ara toplam</span>
                            <strong>&#8378; @Model.TotalAmount</strong>
                        </div>
                        @if (ViewData["RequiresLoginForCheckout"] as bool? == true)
                        {
                            <div class="cart-summary-note">
                                Gecici sepetin korunuyor. Siparisi tamamlamak icin giris yaptiginda bu sepet hesabina aktarilacak.
                            </div>
                            <a href="/login?returnUrl=%2Fcart" class="btn btn-primary cart-summary-link mb-3">Giris Yap ve Devam Et</a>
                        }
                        else
                        {
                            <div class="cart-summary-note">
                                Siparis varsayilan adresinizle olusturulur. Varsayilan adresiniz yoksa hesabinizdaki ilk kayitli adres kullanilir.
                            </div>
                            <form method="post" action="/cart/checkout" class="mb-3">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-primary cart-summary-link">Siparisi Olustur</button>
                            </form>
                        }

                        <a href="/" class="btn btn-outline-primary cart-summary-link">Alisverise Devam Et</a>
                    </aside>
                </div>
            </div>
        }
    </div>
</div>
