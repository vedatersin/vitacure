@model vitacure.Models.ViewModels.Auth.LoginViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="container auth-container">
        <div class="auth-card">
            <div class="auth-eyebrow">Üye Girişi</div>
            <h1 class="auth-title">Vitacure hesabınla giriş yap</h1>
            <p class="auth-subtitle">Alışveriş hesabınla oturum açarak siparişlerini ve hesabını yönetebilirsin.</p>

            @if (TempData["AuthMessage"] is string authMessage)
            {
                <div class="alert alert-warning">@authMessage</div>
            }

            <form method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input asp-for="ReturnUrl" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control auth-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control auth-input" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" />
                    <label asp-for="RememberMe" class="form-check-label"></label>
                </div>

                <div class="auth-footer-link mb-4 text-start">
                    <a href="/forgot-password">Şifremi unuttum</a>
                </div>

                <button type="submit" class="btn auth-submit-btn">Giriş Yap</button>
            </form>

            <div class="auth-footer-link">
                Hesabın yok mu? <a href="/register">Ücretsiz üye ol</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
