@model vitacure.Models.ViewModels.Auth.ResetPasswordViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="container auth-container">
        <div class="auth-card">
            <div class="auth-eyebrow">Yeni Şifre</div>
            <h1 class="auth-title">Şifreni güncelle</h1>
            <p class="auth-subtitle">Yeni şifren en az 6 karakter olmalı ve mevcut parola kurallarına uymalıdır.</p>

            <form method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <input asp-for="Email" type="hidden" />
                <input asp-for="Token" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control auth-input" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label"></label>
                    <input asp-for="ConfirmPassword" class="form-control auth-input" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn auth-submit-btn">Şifreyi Güncelle</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
