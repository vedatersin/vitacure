@model vitacure.Models.ViewModels.Auth.ForgotPasswordViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="container auth-container">
        <div class="auth-card">
            <div class="auth-eyebrow">Sifre Sifirlama</div>
            <h1 class="auth-title">Yeni sifre baglantisi olustur</h1>
            <p class="auth-subtitle">Kayitli müşteri e-postanizi girin. E-posta servisi hazir olana kadar baglantiyi bu ekranda göstereceğiz.</p>

            <form method="post" class="auth-form">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control auth-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <button type="submit" class="btn auth-submit-btn">Baglanti Olustur</button>
            </form>

            @if (!string.IsNullOrWhiteSpace(Model.Message))
            {
                <div class="alert alert-info mt-4">@Model.Message</div>
            }

            @if (!string.IsNullOrWhiteSpace(Model.ResetUrl))
            {
                <div class="auth-footer-link mt-3">
                    Sifreyi sifirla: <a href="@Model.ResetUrl">Baglantiyi aç</a>
                </div>
            }

            <div class="auth-footer-link">
                Giris ekranina dönmek için <a href="/login">buraya tikla</a>.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
