@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="container auth-container">
        <div class="auth-card">
            <div class="auth-eyebrow">Doğrulama Tamam</div>
            <h1 class="auth-title">E-posta adresin doğrulandı</h1>
