@model vitacure.Models.ViewModels.Account.AccountDashboardViewModel

@section Styles {
    <link rel="stylesheet" href="~/css/pages/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/components/product-card.css" asp-append-version="true" />
}

@{
    var addressFormAction = Model.EditingAddressId.HasValue ? "/account/addresses/update" : "/account/addresses/create";
    var addressFormTitle = Model.EditingAddressId.HasValue ? "Adresi duzenle" : "Yeni adres ekle";
    var addressFormButton = Model.EditingAddressId.HasValue ? "Adresi Guncelle" : "Adresi Kaydet";
    var addressModel = Model.EditingAddressId.HasValue ? Model.EditAddress : Model.NewAddress;
    var currentSection = (ViewData["AccountSection"] as string ?? "profile").ToLowerInvariant();
    var sectionItems = new[]
    {
        new { Id = "profile", Label = "Profil", Description = "Hesap bilgilerini guncelle" },
        new { Id = "orders", Label = "Siparisler", Description = "Gecmis siparislerini incele" },
        new { Id = "favorites", Label = "Favoriler", Description = "Kaydettigin urunleri gor" },
        new { Id = "addresses", Label = "Adresler", Description = "Teslimat adreslerini yonet" }
    };
}

<div class="auth-page account-page">
    <div class="container auth-container auth-container-wide">
        <div class="account-shell">
            <aside class="account-sidebar">
                <div class="account-sidebar-card">
                    <div class="auth-eyebrow">Storefront Hesap</div>
                    <h1 class="account-sidebar-title">@Model.FullName</h1>
                    <p class="account-sidebar-subtitle">@Model.Email</p>

                    <div class="account-sidebar-metrics">
                        <div class="account-sidebar-metric">
                            <span>Favoriler</span>
                            <strong>@Model.FavoriteCount urun</strong>
                        </div>
                        <div class="account-sidebar-metric">
                            <span>Adresler</span>
                            <strong>@Model.AddressCount kayit</strong>
                        </div>
                        <div class="account-sidebar-metric">
                            <span>Siparisler</span>
                            <strong>@Model.OrderCount siparis</strong>
                        </div>
                    </div>
                </div>

                <nav class="account-nav" aria-label="Hesap bolumleri">
                    @foreach (var item in sectionItems)
                    {
                        var isActive = string.Equals(currentSection, item.Id, StringComparison.OrdinalIgnoreCase);
                        <a href="/account?section=@item.Id#@item.Id" class="account-nav-link @(isActive ? "is-active" : null)">
                            <span class="account-nav-label">@item.Label</span>
                            <small>@item.Description</small>
                        </a>
                    }
                </nav>

                <form method="post" action="/logout" class="account-logout-form">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn auth-submit-btn">Cikis Yap</button>
                </form>
            </aside>

            <div class="account-content">
                <div class="auth-card account-card">
                    <div class="account-page-header">
                        <div>
                            <div class="auth-eyebrow">Hesabim</div>
                            <h2 class="auth-title account-main-title">Storefront ile butunlesik hesap alani</h2>
                            <p class="auth-subtitle">Ust menu ve marka dili korunurken profil, siparis, favori ve adres yonetimini tek akista topluyoruz.</p>
                        </div>
                    </div>

                    <div class="auth-account-grid">
                        <div class="auth-account-item">
                            <span>Hesap Tipi</span>
                            <strong>Musteri</strong>
                        </div>
                        <div class="auth-account-item">
                            <span>Olusturulma</span>
                            <strong>@Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                        <div class="auth-account-item">
                            <span>Favoriler</span>
                            <strong>@Model.FavoriteCount urun</strong>
                        </div>
                        <div class="auth-account-item">
                            <span>Adresler</span>
                            <strong>@Model.AddressCount kayit</strong>
                        </div>
                        <div class="auth-account-item">
                            <span>Siparisler</span>
                            <strong>@Model.OrderCount siparis</strong>
                        </div>
                    </div>

                    <div class="auth-account-sections mt-4">
                        @if (TempData["CheckoutMessage"] is string checkoutMessage)
                        {
                            <div class="alert @(string.Equals(TempData["CheckoutMessageType"] as string, "success", StringComparison.OrdinalIgnoreCase) ? "alert-success" : "alert-warning")">
                                @checkoutMessage
                            </div>
                        }

                        @if (TempData["AccountMessage"] is string accountMessage)
                        {
                            <div class="alert alert-info">
                                @accountMessage
                            </div>
                        }

                        <section class="auth-account-panel" id="profile">
                            <div class="auth-panel-head">
                                <div>
                                    <div class="auth-eyebrow">Profil</div>
                                    <h2 class="auth-panel-title">Hesap bilgilerin</h2>
                                </div>
                            </div>

                            <form method="post" action="/account/profile/update" class="auth-form">
                                @Html.AntiForgeryToken()

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label asp-for="Profile.FullName" class="form-label"></label>
                                        <input asp-for="Profile.FullName" class="form-control auth-input" />
                                        <span asp-validation-for="Profile.FullName" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Profile.Email" class="form-label"></label>
                                        <input asp-for="Profile.Email" class="form-control auth-input" />
                                        <span asp-validation-for="Profile.Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-6">
                                        <label asp-for="Profile.PhoneNumber" class="form-label"></label>
                                        <input asp-for="Profile.PhoneNumber" class="form-control auth-input" />
                                        <span asp-validation-for="Profile.PhoneNumber" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="auth-admin-actions mt-4">
                                    <button type="submit" class="btn auth-submit-btn auth-secondary-btn">Profili Guncelle</button>
                                </div>
                            </form>
                        </section>

                        <section class="auth-account-panel" id="orders">
                            <div class="auth-panel-head">
                                <div>
                                    <div class="auth-eyebrow">Siparisler</div>
                                    <h2 class="auth-panel-title">Siparis gecmisin</h2>
                                </div>
                            </div>

                            @if (Model.Orders.Count > 0)
                            {
                                <div class="table-responsive">
                                    <table class="table auth-table">
                                        <thead>
                                            <tr>
                                                <th>No</th>
                                                <th>Tarih</th>
                                                <th>Durum</th>
                                                <th>Adet</th>
                                                <th>Tutar</th>
                                                <th>Icerik</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var order in Model.Orders)
                                            {
                                                <tr>
                                                    <td>@order.OrderNumber</td>
                                                    <td>@order.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                                                    <td>@order.Status</td>
                                                    <td>@order.TotalQuantity</td>
                                                    <td>&#8378; @order.TotalAmount</td>
                                                    <td>@string.Join(", ", order.Items.Select(item => $"{item.ProductName} x{item.Quantity}"))</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <p class="auth-empty-state">Henuz siparis olusturmadin. Sepet sayfasindan kayitli adresinle siparis olusturabilirsin.</p>
                            }
                        </section>

                        <section class="auth-account-panel" id="favorites">
                            <div class="auth-panel-head">
                                <div>
                                    <div class="auth-eyebrow">Favoriler</div>
                                    <h2 class="auth-panel-title">Kaydettigin urunler</h2>
                                </div>
                            </div>

                            @if (Model.FavoriteProducts.Count > 0)
                            {
                                <div class="row g-4">
                                    @foreach (var product in Model.FavoriteProducts)
                                    {
                                        <div class="col-lg-4 col-md-6">
                                            @await Html.PartialAsync("~/Views/Shared/Partials/_ProductCard.cshtml", product)
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="auth-empty-state">Henuz favori urun eklemedin. Urun kartlarindaki kalp butonu ile burada bir liste olusturabilirsin.</p>
                            }
                        </section>

                        <section class="auth-account-panel" id="addresses">
                            <div class="auth-panel-head">
                                <div>
                                    <div class="auth-eyebrow">Adresler</div>
                                    <h2 class="auth-panel-title">Teslimat adreslerin</h2>
                                </div>
                            </div>

                            @if (Model.Addresses.Count > 0)
                            {
                                <div class="auth-checkbox-grid mb-4">
                                    @foreach (var address in Model.Addresses)
                                    {
                                        <div class="auth-checkbox-card auth-address-card">
                                            <span>@address.Title @if (address.IsDefault) { <small class="auth-inline-badge">Varsayilan</small> }</span>
                                            <small>@address.RecipientName - @address.PhoneNumber</small>
                                            <small>@address.District / @address.City</small>
                                            <small>@address.AddressLine</small>
                                            @if (!string.IsNullOrWhiteSpace(address.PostalCode))
                                            {
                                                <small>Posta Kodu: @address.PostalCode</small>
                                            }

                                            <div class="auth-admin-actions mt-3">
                                                <a href="/account?section=addresses&editAddressId=@address.Id#addresses" class="btn auth-submit-btn auth-tertiary-btn">Duzenle</a>
                                                <form method="post" action="/account/addresses/delete">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="addressId" value="@address.Id" />
                                                    <button type="submit" class="btn auth-submit-btn auth-secondary-btn">Sil</button>
                                                </form>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }

                            <div class="auth-panel-head">
                                <div>
                                    <div class="auth-eyebrow">Adres Formu</div>
                                    <h3 class="auth-panel-title">@addressFormTitle</h3>
                                </div>
                            </div>

                            <form method="post" action="@addressFormAction" class="auth-form">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="Id" value="@addressModel.Id" />

                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label" for="address-title">Adres Basligi</label>
                                        <input id="address-title" name="Title" value="@addressModel.Title" class="form-control auth-input" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label" for="address-recipient">Teslim Alacak Kisi</label>
                                        <input id="address-recipient" name="RecipientName" value="@addressModel.RecipientName" class="form-control auth-input" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" for="address-phone">Telefon</label>
                                        <input id="address-phone" name="PhoneNumber" value="@addressModel.PhoneNumber" class="form-control auth-input" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" for="address-city">Il</label>
                                        <input id="address-city" name="City" value="@addressModel.City" class="form-control auth-input" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" for="address-district">Ilce</label>
                                        <input id="address-district" name="District" value="@addressModel.District" class="form-control auth-input" />
                                    </div>
                                    <div class="col-md-8">
                                        <label class="form-label" for="address-line">Adres</label>
                                        <textarea id="address-line" name="AddressLine" class="form-control auth-textarea" rows="4">@addressModel.AddressLine</textarea>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label" for="address-postal">Posta Kodu</label>
                                        <input id="address-postal" name="PostalCode" value="@addressModel.PostalCode" class="form-control auth-input" />

                                        <div class="form-check mt-3">
                                            <input type="hidden" name="IsDefault" value="false" />
                                            <input class="form-check-input" type="checkbox" id="address-default" name="IsDefault" value="true" @(addressModel.IsDefault ? "checked" : null) />
                                            <label class="form-check-label" for="address-default">Varsayilan Adres</label>
                                        </div>
                                    </div>
                                </div>

                                <div class="auth-admin-actions mt-4">
                                    <button type="submit" class="btn auth-submit-btn auth-secondary-btn">@addressFormButton</button>
                                    @if (Model.EditingAddressId.HasValue)
                                    {
                                        <a href="/account?section=addresses#addresses" class="btn auth-submit-btn auth-tertiary-btn">Vazgec</a>
                                    }
                                </div>
                            </form>
                        </section>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/components/product-card.js" asp-append-version="true"></script>
}
